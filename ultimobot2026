void GuardarEstadoCompleto()
{
   string prefijo = "EA_STATE_" + _Symbol + "_";
   
   // --- Estado del sistema ---
   GlobalVariableSet(prefijo + "ACTIVO", g_sistema_activo ? 1.0 : 0.0);
   GlobalVariableSet(prefijo + "TIPO_INICIAL", (double)g_tipo_inicial);
   GlobalVariableSet(prefijo + "NIVEL_ACTUAL", (double)g_nivel_actual);
   GlobalVariableSet(prefijo + "PRECIO_E1", g_precio_entrada1);
