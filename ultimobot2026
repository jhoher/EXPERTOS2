//+------------------------------------------------------------------+
//| Calcular volúmenes totales BUY y SELL                           |
//| CRÍTICO: Esta función DEBE calcular correctamente los volúmenes |
//+------------------------------------------------------------------+
void CalcularVolumenesTotales(double &volumenBuyTotal, double &volumenSellTotal)
{
   volumenBuyTotal = 0;
   volumenSellTotal = 0;
   
   CPositionInfo posInfo;
   
   for(int i = 0; i < PositionsTotal(); i++)
   {
      if(posInfo.SelectByIndex(i))
      {
         if(posInfo.Magic() == g_numero_magico && posInfo.Symbol() == _Symbol)
         {
            double volumen = posInfo.Volume();
            string comentario = posInfo.Comment();
            int nivel = 0;
            
            if(StringFind(comentario, "Nivel_") >= 0)
            {
               nivel = (int)StringToInteger(StringSubstr(comentario, 6));
            }
            
            // Determinar tipo real según nivel
            ENUM_ORDER_TYPE tipoReal;
            if(nivel % 2 == 1)
               tipoReal = g_tipo_inicial;
            else
               tipoReal = (g_tipo_inicial == ORDER_TYPE_BUY) ? ORDER_TYPE_SELL : ORDER_TYPE_BUY;
            
            if(tipoReal == ORDER_TYPE_BUY)
               volumenBuyTotal += volumen;
            else
               volumenSellTotal += volumen;
         }
      }
   }
}

//+------------------------------------------------------------------+
//| Verificar si hay neutralización de volúmenes                     |
//| VERSIÓN MEJORADA: Más estricta para evitar falsos positivos     |
//+------------------------------------------------------------------+
bool VerificarNeutralizacion()
{
   double volBuy = 0, volSell = 0;
   CalcularVolumenesTotales(volBuy, volSell);
   
   // ========== VERIFICACIÓN 1: Ambos lados deben existir ==========
   if(volBuy == 0 || volSell == 0)
      return false;
   // ===============================================================
   
   double diferencia = MathAbs(volBuy - volSell);
   double minVol = SymbolInfoDouble(_Symbol, SYMBOL_VOLUME_MIN);
   
   // ========== VERIFICACIÓN 2: Diferencia mínima ==========
   // Se considera neutralizado si la diferencia es menor al doble del volumen mínimo
   return (diferencia < minVol * 2);
   // =======================================================
}

//+------------------------------------------------------------------+
//| Calcular P&L actual de todas las posiciones                     |
//+------------------------------------------------------------------+
double CalcularPLTotal()
{
   double plTotal = 0;
   CPositionInfo posInfo;
   
   for(int i = 0; i < PositionsTotal(); i++)
   {
      if(posInfo.SelectByIndex(i))
      {
         if(posInfo.Magic() == g_numero_magico && posInfo.Symbol() == _Symbol)
         {
            plTotal += posInfo.Profit() + posInfo.Swap() + posInfo.Commission();
         }
      }
   }
   
   return plTotal;
}

//+------------------------------------------------------------------+
//| Calcular P&L separado por tipo (BUY/SELL)                       |
//| CORRECCIÓN CRÍTICA: Usa tipo REAL de la posición MT5            |
//+------------------------------------------------------------------+
void CalcularPLPorTipo(double &plBuy, double &plSell)
{
   plBuy = 0;
   plSell = 0;
   
   CPositionInfo posInfo;
   
   for(int i = 0; i < PositionsTotal(); i++)
   {
      if(posInfo.SelectByIndex(i))
      {
         if(posInfo.Magic() == g_numero_magico && posInfo.Symbol() == _Symbol)
         {
            double pl = posInfo.Profit() + posInfo.Swap() + posInfo.Commission();
            
            // ========== CORRECCIÓN CRÍTICA ==========
            // SIEMPRE usar tipo REAL de la posición según MT5
            // NO calcular por nivel ni patrón
            if(posInfo.PositionType() == POSITION_TYPE_BUY)
               plBuy += pl;
            else
               plSell += pl;
            // =========================================
         }
      }
   }
}

//+------------------------------------------------------------------+
//| CORRECCIÓN: Lectura de SWAP en posiciones cerradas              |
//|                                                                  |
//| PROBLEMA: MT5 a veces NO reporta el swap en DEAL_SWAP del      |
//| historial de deals. El swap se "pierde" al cerrar posiciones.   |
//|                                                                  |
//| SOLUCIÓN: Leer el swap ANTES de cerrar las ganadoras,           |
//| guardarlo, y sumarlo al cálculo del P&L realizado.              |
//|                                                                  |
//| INSTRUCCIONES:                                                   |
//| Busca la función EjecutarRollOff() COMPLETA en tu código       |
//| y reemplázala TODA por esta versión corregida.                  |
//+------------------------------------------------------------------+

bool EjecutarRollOff()
{
   Print("========================================");
   Print("========== EJECUTANDO ROLL-OFF ==========");
   Print(">>> MODO: CIERRA GANADORAS <<<");
   
   CTrade tradeRollOff;
   CPositionInfo posInfo;
   tradeRollOff.SetExpertMagicNumber(g_numero_magico);
   
   // Calcular P&L por tipo
   double plBuy = 0, plSell = 0;
   CalcularPLPorTipo(plBuy, plSell);
   
   Print("P&L BUY: ", DoubleToString(plBuy, 2), " | P&L SELL: ", DoubleToString(plSell, 2));
   
   bool buyGanando = (plBuy > plSell);
   Print("Lado ganador: ", (buyGanando ? "BUY" : "SELL"));
   Print("Lado perdedor (quedará abierto): ", (buyGanando ? "SELL" : "BUY"));
   
   double punto = SymbolInfoDouble(_Symbol, SYMBOL_POINT);
   int digits = (int)SymbolInfoInteger(_Symbol, SYMBOL_DIGITS);
   
   // ========== GUARDAR PRECIO ACTUAL ANTES DE CERRAR ==========
   double precioActualAntesCierre;
   if(buyGanando)
      precioActualAntesCierre = SymbolInfoDouble(_Symbol, SYMBOL_BID);
   else
      precioActualAntesCierre = SymbolInfoDouble(_Symbol, SYMBOL_ASK);
   
   Print("Precio actual (referencia para orden): ", DoubleToString(precioActualAntesCierre, digits));
   
   // ==========================================================
   // CORRECCIÓN CRÍTICA: LEER SWAP DE *TODAS* LAS POSICIONES
   // ANTES de cerrar ninguna, porque MT5 pierde el swap al cerrar
   // ==========================================================
   Print("========================================");
   Print(">>> PASO 0: LEER SWAP DE TODAS LAS POSICIONES (ANTES DE CERRAR) <<<");
   
   double swapTotalTodasAbiertas = 0;
   
   for(int i = 0; i < PositionsTotal(); i++)
   {
      if(posInfo.SelectByIndex(i))
      {
         if(posInfo.Magic() == g_numero_magico && posInfo.Symbol() == _Symbol)
         {
            ulong ticket = posInfo.Ticket();
            double swapPos = posInfo.Swap();
            ENUM_POSITION_TYPE tipoPosicion = posInfo.PositionType();
            string comentario = posInfo.Comment();
            
            Print("  Pos #", ticket, 
                  " Tipo:", (tipoPosicion == POSITION_TYPE_BUY ? "BUY" : "SELL"),
                  " Com:", comentario,
                  " Swap: ", DoubleToString(swapPos, 2));
            
            swapTotalTodasAbiertas += swapPos;
         }
      }
   }
   
   Print("SWAP TOTAL DE TODAS LAS POSICIONES ABIERTAS: ", DoubleToString(swapTotalTodasAbiertas, 2));
   Print("========================================");
   // ==========================================================
   
   // ========== PASO 1: CERRAR GANADORAS ==========
   Print("========================================");
   Print(">>> PASO 1: CERRANDO GANADORAS <<<");
   
   ulong ticketsCerrar[];
   int contadorTickets = 0;
   double volumenTotalGanadorasCerradas = 0;
   
   for(int i = PositionsTotal() - 1; i >= 0; i--)
   {
      if(posInfo.SelectByIndex(i))
      {
         if(posInfo.Magic() == g_numero_magico && posInfo.Symbol() == _Symbol)
         {
            ENUM_POSITION_TYPE tipoPosicion = posInfo.PositionType();
            
            bool esGanadora = false;
            
            if(buyGanando)
            {
               esGanadora = (tipoPosicion == POSITION_TYPE_BUY);
            }
            else
            {
               esGanadora = (tipoPosicion == POSITION_TYPE_SELL);
            }
            
            if(esGanadora)
            {
               ulong ticket = posInfo.Ticket();
               double volumen = posInfo.Volume();
               string comentario = posInfo.Comment();
               
               Print("  Identificada GANADORA #", ticket, 
                     " Vol:", DoubleToString(volumen, 2),
                     " Tipo:", (tipoPosicion == POSITION_TYPE_BUY ? "BUY" : "SELL"),
                     " Com:", comentario, " → SE CERRARÁ");
               
               ArrayResize(ticketsCerrar, contadorTickets + 1);
               ticketsCerrar[contadorTickets] = ticket;
               contadorTickets++;
               volumenTotalGanadorasCerradas += volumen;
            }
            else
            {
               ulong ticket = posInfo.Ticket();
               double volumen = posInfo.Volume();
               string comentario = posInfo.Comment();
               
               Print("  Identificada PERDEDORA #", ticket, 
                     " Vol:", DoubleToString(volumen, 2),
                     " Tipo:", (tipoPosicion == POSITION_TYPE_BUY ? "BUY" : "SELL"),
                     " Com:", comentario, " → QUEDA ABIERTA");
            }
         }
      }
   }
   
   Print("----------------------------------------------");
   Print("Ganadoras a cerrar: ", contadorTickets);
   Print("Volumen ganadoras cerradas: ", DoubleToString(volumenTotalGanadorasCerradas, 2));
   
   for(int i = 0; i < contadorTickets; i++)
   {
      ulong ticket = ticketsCerrar[i];
      
      if(tradeRollOff.PositionClose(ticket))
      {
         Print("  ✓ Ganadora cerrada #", ticket);
         Sleep(100);
      }
   }
   
   Sleep(200);
   
   // ========== LEER PROFIT DE TODAS LAS CERRADAS ==========
   Print("--- Leyendo TODA la secuencia desde inicio ---");
   
   double profitTodasCerradas = 0;
   double swapTodasCerradas = 0;
   int cantidadCerradas = 0;
   
   datetime desde = g_tiempo_primera_entrada;
   datetime hasta = TimeCurrent();
   
   if(HistorySelect(desde, hasta))
   {
      int totalDeals = HistoryDealsTotal();
      
      for(int i = totalDeals - 1; i >= 0; i--)
      {
         ulong dealTicket = HistoryDealGetTicket(i);
         
         if(dealTicket > 0)
         {
            long magic = HistoryDealGetInteger(dealTicket, DEAL_MAGIC);
            string symbol = HistoryDealGetString(dealTicket, DEAL_SYMBOL);
            long dealEntry = HistoryDealGetInteger(dealTicket, DEAL_ENTRY);
            
            if(magic == g_numero_magico && symbol == _Symbol && dealEntry == DEAL_ENTRY_OUT)
            {
               double profitReal = HistoryDealGetDouble(dealTicket, DEAL_PROFIT);
               double swapReal = HistoryDealGetDouble(dealTicket, DEAL_SWAP);
               double volumen = HistoryDealGetDouble(dealTicket, DEAL_VOLUME);
               ulong positionTicket = HistoryDealGetInteger(dealTicket, DEAL_POSITION_ID);
               
               Print("  Deal #", dealTicket, " Pos #", positionTicket);
               Print("    Profit: ", DoubleToString(profitReal, 2));
               Print("    Swap (deal): ", DoubleToString(swapReal, 2));
               Print("    Volumen: ", DoubleToString(volumen, 2));
               
               profitTodasCerradas += profitReal;
               swapTodasCerradas += swapReal;
               cantidadCerradas++;
            }
         }
      }
   }
   
   Print("----------------------------------------------");
   Print("Total entradas cerradas: ", cantidadCerradas);
   Print("PROFIT TODAS CERRADAS (sin swap): ", DoubleToString(profitTodasCerradas, 2));
   Print("SWAP CERRADAS (del historial): ", DoubleToString(swapTodasCerradas, 2));
   
   // ========== LEER SWAP DE PERDEDORAS ABIERTAS ==========
   Print("--- Leyendo SWAP de perdedoras abiertas ---");
   
   double swapPerdedorasAbiertas = 0;
   int cantidadPerdedorasAbiertas = 0;
   double volumenTotalPerdedoras = 0;
   ENUM_POSITION_TYPE tipoPerdedorasMT5 = POSITION_TYPE_BUY;
   ENUM_ORDER_TYPE tipoPerdedoras = ORDER_TYPE_BUY;
   
   for(int i = 0; i < PositionsTotal(); i++)
   {
      if(posInfo.SelectByIndex(i))
      {
         if(posInfo.Magic() == g_numero_magico && posInfo.Symbol() == _Symbol)
         {
            double swapPos = posInfo.Swap();
            ulong ticket = posInfo.Ticket();
            double volumen = posInfo.Volume();
            
            Print("  Swap perdedora abierta #", ticket, ": ", DoubleToString(swapPos, 2));
            
            swapPerdedorasAbiertas += swapPos;
            volumenTotalPerdedoras += volumen;
            tipoPerdedorasMT5 = posInfo.PositionType();
            tipoPerdedoras = (tipoPerdedorasMT5 == POSITION_TYPE_BUY) ? ORDER_TYPE_BUY : ORDER_TYPE_SELL;
            cantidadPerdedorasAbiertas++;
         }
      }
   }
   
   Print("----------------------------------------------");
   Print("Total perdedoras abiertas: ", cantidadPerdedorasAbiertas);
   Print("Volumen total perdedoras: ", DoubleToString(volumenTotalPerdedoras, 2));
   Print("SWAP PERDEDORAS ABIERTAS: ", DoubleToString(swapPerdedorasAbiertas, 2));
   
   if(cantidadPerdedorasAbiertas == 0)
   {
      Print("✗ ERROR: No hay perdedoras abiertas");
      return false;
   }
   
   // ==========================================================
   // CORRECCIÓN CRÍTICA: CALCULAR SWAP TOTAL REAL
   // Usamos el swap leído ANTES de cerrar (Paso 0) como fuente
   // de verdad, porque MT5 puede perder swap en deals
   // ==========================================================
   Print("========================================");
   Print(">>> SWAP TOTAL REAL (CORRECCIÓN) <<<");
   
   // El swap total real es: swap guardado antes de cerrar + swap de deals de ciclos anteriores
   // Para el ciclo actual: usamos swapTotalTodasAbiertas (leído en Paso 0)
   // Para ciclos anteriores cerrados: usamos swapTodasCerradas del historial
   // PERO: las posiciones del Paso 0 que ahora están cerradas ya tienen su swap en swapTodasCerradas
   //       y las que siguen abiertas tienen su swap en swapPerdedorasAbiertas
   
   // Método más confiable: 
   // swap total = swap leído antes de cerrar (incluye ganadoras + perdedoras actuales)
   //            + swap de deals de ciclos ANTERIORES (cerrados antes de este Roll-Off)
   
   // Identificar swap de deals ANTERIORES a este Roll-Off
   double swapDealsAnteriores = 0;
   
   if(HistorySelect(desde, hasta))
   {
      int totalDeals = HistoryDealsTotal();
      
      for(int i = totalDeals - 1; i >= 0; i--)
      {
         ulong dealTicket = HistoryDealGetTicket(i);
         
         if(dealTicket > 0)
         {
            long magic = HistoryDealGetInteger(dealTicket, DEAL_MAGIC);
            string symbol = HistoryDealGetString(dealTicket, DEAL_SYMBOL);
            long dealEntry = HistoryDealGetInteger(dealTicket, DEAL_ENTRY);
            datetime dealTime = (datetime)HistoryDealGetInteger(dealTicket, DEAL_TIME);
            
            if(magic == g_numero_magico && symbol == _Symbol && dealEntry == DEAL_ENTRY_OUT)
            {
               // Solo deals cerrados ANTES de este Roll-Off (anteriores al último minuto)
               if(dealTime < TimeCurrent() - 5)
               {
                  double swapDeal = HistoryDealGetDouble(dealTicket, DEAL_SWAP);
                  swapDealsAnteriores += swapDeal;
               }
            }
         }
      }
   }
   
   // SWAP TOTAL REAL = swap de posiciones actuales (leído antes de cerrar) + swap de deals anteriores
   double swapTotalReal = swapTotalTodasAbiertas + swapDealsAnteriores;
   
   Print("Swap posiciones actuales (Paso 0): ", DoubleToString(swapTotalTodasAbiertas, 2));
   Print("Swap deals anteriores: ", DoubleToString(swapDealsAnteriores, 2));
   Print("SWAP TOTAL REAL: ", DoubleToString(swapTotalReal, 2));
   Print("========================================");
   // ==========================================================
   
   // ========== PASO 2: COMISIONES TOTALES ==========
   Print("========================================");
   Print(">>> PASO 2: COMISIONES TOTALES <<<");
   
   double comisionesTotales = 0;
   
   // Comisiones de cerradas (usar CalcularComisionPepperstone)
   if(HistorySelect(desde, hasta))
   {
      int totalDeals = HistoryDealsTotal();
      
      for(int i = totalDeals - 1; i >= 0; i--)
      {
         ulong dealTicket = HistoryDealGetTicket(i);
         
         if(dealTicket > 0)
         {
            long magic = HistoryDealGetInteger(dealTicket, DEAL_MAGIC);
            string symbol = HistoryDealGetString(dealTicket, DEAL_SYMBOL);
            long dealEntry = HistoryDealGetInteger(dealTicket, DEAL_ENTRY);
            
            if(magic == g_numero_magico && symbol == _Symbol && dealEntry == DEAL_ENTRY_OUT)
            {
               double volumen = HistoryDealGetDouble(dealTicket, DEAL_VOLUME);
               double comision = CalcularComisionPepperstone(volumen, _Symbol);
               comisionesTotales += comision;
               
               ulong positionTicket = HistoryDealGetInteger(dealTicket, DEAL_POSITION_ID);
               Print("  Comisión cerrada #", positionTicket, ": ", DoubleToString(comision, 2));
            }
         }
      }
   }
   
   // Comisiones de perdedoras abiertas
   for(int i = 0; i < PositionsTotal(); i++)
   {
      if(posInfo.SelectByIndex(i))
      {
         if(posInfo.Magic() == g_numero_magico && posInfo.Symbol() == _Symbol)
         {
            double volumen = posInfo.Volume();
            double comision = CalcularComisionPepperstone(volumen, _Symbol);
            comisionesTotales += comision;
            Print("  Comisión perdedora abierta #", posInfo.Ticket(), ": ", DoubleToString(comision, 2));
         }
      }
   }
   
   Print("----------------------------------------------");
   Print("COMISIONES TOTALES: ", DoubleToString(comisionesTotales, 2));
   
   // ========== PASO 3: CALCULAR P&L REALIZADO ==========
   // CORRECCIÓN: Usar swapTotalReal en vez de solo swap de perdedoras
   Print("========================================");
   Print(">>> PASO 3: P&L REALIZADO (CORREGIDO CON SWAP REAL) <<<");
   
   double plRealizado = profitTodasCerradas + swapTotalReal + swapPerdedorasAbiertas - comisionesTotales;
   
   Print("PROFIT TODAS CERRADAS: ", DoubleToString(profitTodasCerradas, 2));
   Print("SWAP TOTAL REAL (leído antes de cerrar): ", DoubleToString(swapTotalReal, 2));
   Print("SWAP PERDEDORAS ABIERTAS (actual): ", DoubleToString(swapPerdedorasAbiertas, 2));
   Print("COMISIONES TOTALES: -", DoubleToString(comisionesTotales, 2));
   Print("----------------------------------------------");
   Print("P&L REALIZADO: ", DoubleToString(plRealizado, 2));
   
   // ========== PASO 4: CALCULAR TP PARA PERDEDORAS ==========
   Print("========================================");
   Print(">>> PASO 4: CALCULAR TP PARA PERDEDORAS <<<");
   
   double perdidaMaximaPermitida = plRealizado - g_ganancia_objetivo;
   
   Print("P&L REALIZADO: ", DoubleToString(plRealizado, 2));
   Print("GananciaM: ", DoubleToString(g_ganancia_objetivo, 2));
   Print("Pérdida MÁXIMA permitida en perdedoras: ", DoubleToString(perdidaMaximaPermitida, 2));
   
   // Cancelar órdenes de protección anteriores
   COrderInfo ordInfo;
   for(int i = OrdersTotal() - 1; i >= 0; i--)
   {
      if(ordInfo.SelectByIndex(i))
      {
         if(ordInfo.Magic() == g_numero_magico && ordInfo.Symbol() == _Symbol)
         {
            string com = ordInfo.Comment();
            if(StringFind(com, "RollOff_Proteccion") >= 0)
            {
               tradeRollOff.OrderDelete(ordInfo.Ticket());
            }
         }
      }
   }
   
   // Analizar perdedoras abiertas
   Print("--- Analizando perdedoras abiertas ---");
   
   double sumatoriaPrecioVolumenPerdedoras = 0;
   double precioAperturaUltimaPerdedora = 0;
   datetime tiempoMasReciente = 0;
   
   for(int i = 0; i < PositionsTotal(); i++)
   {
      if(posInfo.SelectByIndex(i))
      {
         if(posInfo.Magic() == g_numero_magico && posInfo.Symbol() == _Symbol)
         {
            ulong ticket = posInfo.Ticket();
            double volumen = posInfo.Volume();
            double precioApertura = posInfo.PriceOpen();
            datetime tiempoApertura = posInfo.Time();
            string comentario = posInfo.Comment();
            ENUM_POSITION_TYPE tipoPosicion = posInfo.PositionType();
            
            int nivel = 0;
            if(StringFind(comentario, "Nivel_") >= 0)
            {
               nivel = (int)StringToInteger(StringSubstr(comentario, 6));
            }
            
            Print("  Perdedora #", ticket, 
                  " Tipo:", (tipoPosicion == POSITION_TYPE_BUY ? "BUY" : "SELL"),
                  " Nivel:", nivel, 
                  " Vol:", DoubleToString(volumen, 2));
            Print("    Precio apertura: ", DoubleToString(precioApertura, digits));
            
            sumatoriaPrecioVolumenPerdedoras += precioApertura * volumen;
            
            if(tiempoApertura > tiempoMasReciente)
            {
               tiempoMasReciente = tiempoApertura;
               precioAperturaUltimaPerdedora = precioApertura;
            }
         }
      }
   }
   
   double precioPromedioAperturaPerdedoras = sumatoriaPrecioVolumenPerdedoras / volumenTotalPerdedoras;
   
   Print("----------------------------------------------");
   Print("Precio promedio apertura perdedoras: ", DoubleToString(precioPromedioAperturaPerdedoras, digits));
   
   // ========== EXTRAER VALOR DEL TICK DESDE PERDEDORAS ==========
   double valorTickActual = 0;
   bool tickObtenido = false;
   
   double precioActualCalculo;
   if(tipoPerdedoras == ORDER_TYPE_BUY)
      precioActualCalculo = SymbolInfoDouble(_Symbol, SYMBOL_BID);
   else
      precioActualCalculo = SymbolInfoDouble(_Symbol, SYMBOL_ASK);
   
   for(int i = 0; i < PositionsTotal(); i++)
   {
      if(posInfo.SelectByIndex(i))
      {
         if(posInfo.Magic() == g_numero_magico && posInfo.Symbol() == _Symbol)
         {
            double volumen = posInfo.Volume();
            double precioApertura = posInfo.PriceOpen();
            double profitActual = posInfo.Profit();
            ENUM_POSITION_TYPE tipoPosicion = posInfo.PositionType();
            
            double diferenciaPrecio;
            if(tipoPosicion == POSITION_TYPE_BUY)
               diferenciaPrecio = precioActualCalculo - precioApertura;
            else
               diferenciaPrecio = precioApertura - precioActualCalculo;
            
            double puntosActuales = diferenciaPrecio / punto;
            
            if(MathAbs(puntosActuales) >= 1.0 && MathAbs(profitActual) >= 0.01)
            {
               valorTickActual = MathAbs(profitActual) / MathAbs(puntosActuales) / volumen;
               
               Print(">>> EXTRAYENDO VALOR TICK DESDE PERDEDORA <<<");
               Print("  Posición #", posInfo.Ticket());
               Print("  Precio apertura: ", DoubleToString(precioApertura, digits));
               Print("  Precio AHORA: ", DoubleToString(precioActualCalculo, digits));
               Print("  Puntos actuales: ", DoubleToString(puntosActuales, 1));
               Print("  Profit AHORA: ", DoubleToString(profitActual, 2));
               Print("  Volumen: ", DoubleToString(volumen, 2));
               Print("  → Valor TICK ACTUAL: ", DoubleToString(valorTickActual, 6));
               
               tickObtenido = true;
               break;
            }
         }
      }
   }
   
   if(!tickObtenido || MathAbs(valorTickActual) < 0.1)
   {
      Print("⚠ No se pudo extraer, usando valor aproximado: 0.84");
      valorTickActual = 0.84;
   }
   
   Print("Valor TICK para cálculos: ", DoubleToString(valorTickActual, 6));
   
   // ========== CALCULAR TP PARA PERDEDORAS ==========
   double puntosPermitidos = MathAbs(perdidaMaximaPermitida) / (volumenTotalPerdedoras * valorTickActual);
   
   double precioTP;
   if(tipoPerdedoras == ORDER_TYPE_BUY)
   {
      precioTP = precioPromedioAperturaPerdedoras - (puntosPermitidos * punto);
   }
   else
   {
      precioTP = precioPromedioAperturaPerdedoras + (puntosPermitidos * punto);
   }
   
   precioTP = NormalizeDouble(precioTP, digits);
   
   Print("----------------------------------------------");
   Print(">>> CÁLCULO TP PARA PERDEDORAS <<<");
   Print("Pérdida máxima permitida: ", DoubleToString(perdidaMaximaPermitida, 2));
   Print("Volumen total perdedoras: ", DoubleToString(volumenTotalPerdedoras, 2));
   Print("Valor TICK: ", DoubleToString(valorTickActual, 6));
   Print("Puntos de pérdida permitidos: ", DoubleToString(puntosPermitidos, 1));
   Print("Precio promedio apertura: ", DoubleToString(precioPromedioAperturaPerdedoras, digits));
   Print("TP calculado: ", DoubleToString(precioTP, digits));
   Print("Precio actual: ", DoubleToString(precioActualCalculo, digits));
   
   // Verificar si el TP ya fue superado
   bool tpYaSuperado = false;
   if(tipoPerdedoras == ORDER_TYPE_BUY)
      tpYaSuperado = (precioActualCalculo >= precioTP);
   else
      tpYaSuperado = (precioActualCalculo <= precioTP);
   
   if(tpYaSuperado)
   {
      Print("========================================");
      Print(">>> TP YA SUPERADO - OBJETIVO CUMPLIDO <<<");
      Print(">>> Cerrando TODAS las posiciones");
      Print("========================================");
      
      for(int i = PositionsTotal() - 1; i >= 0; i--)
      {
         if(posInfo.SelectByIndex(i))
         {
            if(posInfo.Magic() == g_numero_magico && posInfo.Symbol() == _Symbol)
            {
               ulong ticket = posInfo.Ticket();
               if(tradeRollOff.PositionClose(ticket))
               {
                  Print("  ✓ Cerrada #", ticket);
                  Sleep(50);
               }
            }
         }
      }
      
      for(int i = OrdersTotal() - 1; i >= 0; i--)
      {
         if(ordInfo.SelectByIndex(i))
         {
            if(ordInfo.Magic() == g_numero_magico && ordInfo.Symbol() == _Symbol)
            {
               tradeRollOff.OrderDelete(ordInfo.Ticket());
            }
         }
      }
      
      Print(">>> OBJETIVO ALCANZADO");
      return true;
   }
   
   // ========== PASO 5: CONFIGURAR TP EN PERDEDORAS ==========
   Print("========================================");
   Print(">>> PASO 5: CONFIGURAR TP EN PERDEDORAS <<<");
   
   int tpsConfigurados = 0;
   for(int i = 0; i < PositionsTotal(); i++)
   {
      if(posInfo.SelectByIndex(i))
      {
         if(posInfo.Magic() == g_numero_magico && posInfo.Symbol() == _Symbol)
         {
            ulong ticket = posInfo.Ticket();
            
            if(tradeRollOff.PositionModify(ticket, 0, precioTP))
            {
               Print("  ✓ TP configurado en perdedora #", ticket, " → ", DoubleToString(precioTP, digits));
               tpsConfigurados++;
            }
            else
            {
               Print("  ✗ Error TP #", ticket, " Error:", GetLastError());
            }
         }
      }
   }
   
   Print("TPs configurados: ", tpsConfigurados);
   
   // ========== PASO 6: AFINAR TP ==========
   Print("========================================");
   Print(">>> PASO 6: AFINAR TP <<<");
   Print("Pérdida máxima permitida: ", DoubleToString(perdidaMaximaPermitida, 2));
   Print("GananciaM objetivo: ", DoubleToString(g_ganancia_objetivo, 2));
   
   double valorTickRecalculado = 0;
   bool tickRecalculado = false;
   
   double precioAhoraCalculo;
   if(tipoPerdedoras == ORDER_TYPE_BUY)
      precioAhoraCalculo = SymbolInfoDouble(_Symbol, SYMBOL_BID);
   else
      precioAhoraCalculo = SymbolInfoDouble(_Symbol, SYMBOL_ASK);
   
   for(int i = 0; i < PositionsTotal(); i++)
   {
      if(posInfo.SelectByIndex(i))
      {
         if(posInfo.Magic() == g_numero_magico && posInfo.Symbol() == _Symbol)
         {
            double volumen = posInfo.Volume();
            double precioApertura = posInfo.PriceOpen();
            double profitActual = posInfo.Profit();
            ENUM_POSITION_TYPE tipoPosicion = posInfo.PositionType();
            
            double diferenciaPrecio;
            if(tipoPosicion == POSITION_TYPE_BUY)
               diferenciaPrecio = precioAhoraCalculo - precioApertura;
            else
               diferenciaPrecio = precioApertura - precioAhoraCalculo;
            
            double puntosActuales = diferenciaPrecio / punto;
            
            if(MathAbs(puntosActuales) >= 1.0 && MathAbs(profitActual) >= 0.01)
            {
               valorTickRecalculado = MathAbs(profitActual) / MathAbs(puntosActuales) / volumen;
               
               Print(">>> RECALCULANDO VALOR TICK <<<");
               Print("  Posición #", posInfo.Ticket());
               Print("  Puntos actuales: ", DoubleToString(puntosActuales, 1));
               Print("  Profit AHORA: ", DoubleToString(profitActual, 2));
               Print("  → Valor TICK RECALCULADO: ", DoubleToString(valorTickRecalculado, 6));
               
               tickRecalculado = true;
               break;
            }
         }
      }
   }
   
   if(!tickRecalculado || MathAbs(valorTickRecalculado) < 0.1)
   {
      valorTickRecalculado = valorTickActual;
   }
   
   Print("Valor TICK para cálculos: ", DoubleToString(valorTickRecalculado, 6));
   
   double perdidaTotalEsperada = 0;
   int posicionesConTP = 0;
   
   for(int i = 0; i < PositionsTotal(); i++)
   {
      if(posInfo.SelectByIndex(i))
      {
         if(posInfo.Magic() == g_numero_magico && posInfo.Symbol() == _Symbol)
         {
            double tp = posInfo.TakeProfit();
            if(tp != 0)
            {
               double precioApertura = posInfo.PriceOpen();
               double volumen = posInfo.Volume();
               ENUM_POSITION_TYPE tipoPosicion = posInfo.PositionType();
               
               double diferenciaTP;
               if(tipoPosicion == POSITION_TYPE_BUY)
                  diferenciaTP = tp - precioApertura;
               else
                  diferenciaTP = precioApertura - tp;
               
               double puntosTP = diferenciaTP / punto;
               double profitEsperado = puntosTP * volumen * valorTickRecalculado;
               
               Print("  Pos #", posInfo.Ticket(), " Vol:", DoubleToString(volumen, 2));
               Print("    TP: ", DoubleToString(tp, digits), " Puntos: ", DoubleToString(puntosTP, 1));
               Print("    Pérdida esperada: ", DoubleToString(profitEsperado, 2));
               
               perdidaTotalEsperada += profitEsperado;
               posicionesConTP++;
            }
         }
      }
   }
   
   Print("----------------------------------------------");
   Print("PÉRDIDA TOTAL esperada (TP actual): ", DoubleToString(perdidaTotalEsperada, 2));
   Print("Pérdida máxima permitida: ", DoubleToString(perdidaMaximaPermitida, 2));
   
   double diferencia = perdidaTotalEsperada - (-perdidaMaximaPermitida);
   Print("Diferencia: ", DoubleToString(diferencia, 3));
   
   double resultadoProyectado = plRealizado + perdidaTotalEsperada;
   Print("Resultado proyectado: ", DoubleToString(resultadoProyectado, 3));
   
   bool peligroCritico = (resultadoProyectado <= 0.005);
   
   if(peligroCritico)
   {
      Print("========================================");
      Print("🚨 PELIGRO CRÍTICO DETECTADO");
      Print("   Resultado proyectado: ", DoubleToString(resultadoProyectado, 3));
      Print("   ¡Resultado sería NEGATIVO o CERO!");
      Print("   MODO EMERGENCIA: Búsqueda exhaustiva");
      Print("========================================");
   }
   
   if(peligroCritico || MathAbs(resultadoProyectado - g_ganancia_objetivo) > 0.015)
   {
      Print(">>> Iniciando búsqueda de TP óptimo...");
      
      double mejorTP = precioTP;
      double mejorResultado = resultadoProyectado;
      int iteracionMejor = 0;
      bool tpSeguroEncontrado = false;
      
      int rangoInicio, rangoFin;
      
      if(peligroCritico)
      {
         rangoInicio = 1;
         rangoFin = 100;
         Print("MODO EMERGENCIA: Búsqueda de i=", rangoInicio, " a ", rangoFin);
      }
      else
      {
         rangoInicio = -10;
         rangoFin = 10;
         Print("Modo estándar: Búsqueda de i=", rangoInicio, " a ", rangoFin);
      }
      
      for(int i = rangoInicio; i <= rangoFin; i++)
      {
         double tpPrueba;
         if(tipoPerdedoras == ORDER_TYPE_BUY)
            tpPrueba = precioTP + (i * punto);
         else
            tpPrueba = precioTP - (i * punto);
         
         tpPrueba = NormalizeDouble(tpPrueba, digits);
         
         double perdidaConEstTP = 0;
         
         for(int j = 0; j < PositionsTotal(); j++)
         {
            if(posInfo.SelectByIndex(j))
            {
               if(posInfo.Magic() == g_numero_magico && posInfo.Symbol() == _Symbol)
               {
                  double precioApertura = posInfo.PriceOpen();
                  double volumen = posInfo.Volume();
                  ENUM_POSITION_TYPE tipoPosicion = posInfo.PositionType();
                  
                  double diferenciaTP;
                  if(tipoPosicion == POSITION_TYPE_BUY)
                     diferenciaTP = tpPrueba - precioApertura;
                  else
                     diferenciaTP = precioApertura - tpPrueba;
                  
                  double puntosTP = diferenciaTP / punto;
                  double profitEsperado = puntosTP * volumen * valorTickRecalculado;
                  
                  perdidaConEstTP += profitEsperado;
               }
            }
         }
         
         double resultadoConEstTP = plRealizado + perdidaConEstTP;
         
         if(peligroCritico)
         {
            if(i <= 10 || i % 5 == 0)
            {
               Print("  i=", i, " TP:", DoubleToString(tpPrueba, digits),
                     " Resultado:", DoubleToString(resultadoConEstTP, 3));
            }
         }
         
         if(peligroCritico)
         {
            if(resultadoConEstTP >= g_ganancia_objetivo && !tpSeguroEncontrado)
            {
               mejorTP = tpPrueba;
               mejorResultado = resultadoConEstTP;
               iteracionMejor = i;
               tpSeguroEncontrado = true;
               
               Print("========================================");
               Print("✅ TP SEGURO ENCONTRADO");
               Print("   Iteración: ", i);
               Print("   TP: ", DoubleToString(mejorTP, digits));
               Print("   Resultado proyectado: ", DoubleToString(mejorResultado, 3));
               Print("========================================");
               
               break;
            }
         }
         else
         {
            if(MathAbs(resultadoConEstTP - g_ganancia_objetivo) < MathAbs(mejorResultado - g_ganancia_objetivo))
            {
               mejorTP = tpPrueba;
               mejorResultado = resultadoConEstTP;
               iteracionMejor = i;
            }
         }
      }
      
      Print("----------------------------------------------");
      Print(">>> RESULTADO DE BÚSQUEDA <<<");
      Print("TP anterior: ", DoubleToString(precioTP, digits));
      Print("TP óptimo: ", DoubleToString(mejorTP, digits));
      Print("Iteración: ", iteracionMejor);
      Print("Resultado FINAL proyectado: ", DoubleToString(mejorResultado, 3));
      
      if(mejorTP != precioTP)
      {
         Print(">>> Aplicando TP óptimo...");
         
         int tpsAjustados = 0;
         for(int i = 0; i < PositionsTotal(); i++)
         {
            if(posInfo.SelectByIndex(i))
            {
               if(posInfo.Magic() == g_numero_magico && posInfo.Symbol() == _Symbol)
               {
                  ulong ticket = posInfo.Ticket();
                  
                  if(tradeRollOff.PositionModify(ticket, 0, mejorTP))
                  {
                     Print("  ✓ TP ajustado #", ticket, " → ", DoubleToString(mejorTP, digits));
                     tpsAjustados++;
                  }
               }
            }
         }
         
         Print("TPs ajustados: ", tpsAjustados);
         Print("----------------------------------------------");
         Print("RESULTADO FINAL esperado: ", DoubleToString(mejorResultado, 2));
         
         precioTP = mejorTP;
      }
   }
   else
   {
      Print(">>> Diferencia aceptable, no se requiere ajuste");
      Print(">>> Resultado proyectado: ", DoubleToString(resultadoProyectado, 3), " ✓");
   }
   
   Print("========================================");
   
   // ========== ORDEN PROTECCIÓN NEUTRALIZADORA ==========
   Print("----------------------------------------------");
   Print(">>> ORDEN PROTECCIÓN NEUTRALIZADORA <<<");
   
   double precioOrdenPendiente;
   ENUM_ORDER_TYPE tipoOrdenPendiente;
   int ticksProteccion = 50;
   
   if(tipoPerdedoras == ORDER_TYPE_BUY)
   {
      precioOrdenPendiente = precioActualAntesCierre - (ticksProteccion * punto);
      tipoOrdenPendiente = ORDER_TYPE_SELL_STOP;
   }
   else
   {
      precioOrdenPendiente = precioActualAntesCierre + (ticksProteccion * punto);
      tipoOrdenPendiente = ORDER_TYPE_BUY_STOP;
   }
   
   precioOrdenPendiente = NormalizeDouble(precioOrdenPendiente, digits);
   
   Print("Precio cierre ganadoras: ", DoubleToString(precioActualAntesCierre, digits));
   Print("Distancia protección: ", ticksProteccion, " ticks");
   Print("Tipo: ", (tipoOrdenPendiente == ORDER_TYPE_BUY_STOP ? "BUY STOP" : "SELL STOP"));
   Print("Volumen: ", DoubleToString(volumenTotalPerdedoras, 2));
   Print("Precio orden: ", DoubleToString(precioOrdenPendiente, digits));
   
   if(tradeRollOff.OrderOpen(_Symbol, tipoOrdenPendiente, volumenTotalPerdedoras, 0, 
                      precioOrdenPendiente, 0, 0, 
                      ORDER_TIME_GTC, 0, 
                      "RollOff_Proteccion"))
   {
      Print("✓ Orden protección #", tradeRollOff.ResultOrder());
   }
   
   // ========== PRECIO REFERENCIA ==========
   Print("----------------------------------------------");
   Print(">>> PRECIO REFERENCIA <<<");
   
   g_precio_activacion_roll_off = precioActualAntesCierre;
   Print("✓ ACTUALIZADO (precio cierre ganadoras): ", DoubleToString(g_precio_activacion_roll_off, digits));
   
   Print("==========================================");
   Print(">>> Roll-Off completado (MODO CIERRA GANADORAS)");
   Print("==========================================");
   
   g_ultimo_roll_off = TimeCurrent();
   
   return true;
}


//+------------------------------------------------------------------+
//| MonitorearGanadorasRollOff - VERSIÓN CORREGIDA                  |
//+------------------------------------------------------------------+
void MonitorearGanadorasRollOff()
{
   if(!g_roll_off_activo) return;
   if(!g_sistema_activo) return;
   
   static datetime ultimoRollOffMonitor = 0;
   
   if(g_ultimo_roll_off > ultimoRollOffMonitor)
   {
      ultimoRollOffMonitor = g_ultimo_roll_off;
      Print(">>> MonitorearGanadoras: Esperando siguiente tick después de Roll-Off");
      return;
   }
   
   CPositionInfo posInfo;
   CTrade tradeMonitor;
   tradeMonitor.SetExpertMagicNumber(g_numero_magico);
   
   int posicionesAbiertas = 0;
   for(int i = 0; i < PositionsTotal(); i++)
   {
      if(posInfo.SelectByIndex(i))
      {
         if(posInfo.Magic() == g_numero_magico && posInfo.Symbol() == _Symbol)
         {
            posicionesAbiertas++;
         }
      }
   }
   
   if(posicionesAbiertas == 0)
   {
      Print("========================================");
      Print(">>> TP ALCANZADO - OBJETIVO CUMPLIDO <<<");
      Print("========================================");
      
      COrderInfo ordInfo;
      for(int i = OrdersTotal() - 1; i >= 0; i--)
      {
         if(ordInfo.SelectByIndex(i))
         {
            if(ordInfo.Magic() == g_numero_magico && ordInfo.Symbol() == _Symbol)
            {
               string com = ordInfo.Comment();
               if(StringFind(com, "RollOff_Proteccion") >= 0)
               {
                  tradeMonitor.OrderDelete(ordInfo.Ticket());
               }
            }
         }
      }
      
      g_roll_off_activo = false;
      g_sistema_activo = false;
      g_nivel_actual = 0;
      g_tiempo_primera_entrada = 0;
      g_orden_neutralizadora_activada = false;
      
      Print(">>> Variables reseteadas - Sistema listo");
      return;
   }
   
   // ========== DETECCIÓN DE ORDEN NEUTRALIZADORA ACTIVADA ==========
   
   static int posicionesAnteriores = 0;
   
   bool ordenNeutralizadoraActivada = (posicionesAbiertas > posicionesAnteriores);
   
   if(ordenNeutralizadoraActivada)
   {
      Print("========================================");
      Print(">>> ORDEN NEUTRALIZADORA ACTIVADA <<<");
      Print("Posiciones anteriores: ", posicionesAnteriores);
      Print("Posiciones actuales: ", posicionesAbiertas);
      Print("========================================");
      
      g_orden_neutralizadora_activada = true;
      
      datetime tiempoMasReciente = 0;
      double precioUltimaEntrada = 0;
      int nivelUltimaEntrada = 0;
      
      for(int i = 0; i < PositionsTotal(); i++)
      {
         if(posInfo.SelectByIndex(i))
         {
            if(posInfo.Magic() == g_numero_magico && posInfo.Symbol() == _Symbol)
            {
               datetime tiempoApertura = posInfo.Time();
               
               if(tiempoApertura > tiempoMasReciente)
               {
                  tiempoMasReciente = tiempoApertura;
                  precioUltimaEntrada = posInfo.PriceOpen();
                  
                  string comentario = posInfo.Comment();
                  if(StringFind(comentario, "Nivel_") >= 0)
                  {
                     nivelUltimaEntrada = (int)StringToInteger(StringSubstr(comentario, 6));
                  }
               }
            }
         }
      }
      
      if(precioUltimaEntrada > 0)
      {
         g_precio_activacion_roll_off = precioUltimaEntrada;
         
         Print(">>> PRECIO REFERENCIA ACTUALIZADO <<<");
         Print(">>> Última entrada (Nivel ", nivelUltimaEntrada, "): ", 
               DoubleToString(precioUltimaEntrada, _Digits));
         Print(">>> g_precio_activacion_roll_off = ", 
               DoubleToString(g_precio_activacion_roll_off, _Digits));
      }
      
      Print(">>> NEUTRALIZACIÓN ACTIVADA POR ORDEN <<<");
      Print(">>> QUITANDO TODOS LOS TP/SL <<<");
      
      int tpSlQuitados = 0;
      
      for(int i = 0; i < PositionsTotal(); i++)
      {
         if(posInfo.SelectByIndex(i))
         {
            if(posInfo.Magic() == g_numero_magico && posInfo.Symbol() == _Symbol)
            {
               ulong ticket = posInfo.Ticket();
               double tp = posInfo.TakeProfit();
               double sl = posInfo.StopLoss();
               
               if(tp != 0 || sl != 0)
               {
                  if(tradeMonitor.PositionModify(ticket, 0, 0))
                  {
                     Print("  ✓ TP/SL quitados #", ticket);
                     tpSlQuitados++;
                     Sleep(50);
                  }
               }
            }
         }
      }
      
      Print(">>> TPs quitados: ", tpSlQuitados);
      
      COrderInfo ordInfo;
      int ordenesCanceladas = 0;
      for(int i = OrdersTotal() - 1; i >= 0; i--)
      {
         if(ordInfo.SelectByIndex(i))
         {
            if(ordInfo.Magic() == g_numero_magico && ordInfo.Symbol() == _Symbol)
            {
               string com = ordInfo.Comment();
               if(StringFind(com, "RollOff_Proteccion") >= 0)
               {
                  if(tradeMonitor.OrderDelete(ordInfo.Ticket()))
                  {
                     Print("  ✓ Orden cancelada #", ordInfo.Ticket());
                     ordenesCanceladas++;
                  }
               }
            }
         }
      }
      
      Print(">>> Órdenes canceladas: ", ordenesCanceladas);
      Print("========================================");
   }
   
   posicionesAnteriores = posicionesAbiertas;
   
   static datetime ultimoReporte = 0;
   if(TimeCurrent() - ultimoReporte > 10)
   {
      int digits = (int)SymbolInfoInteger(_Symbol, SYMBOL_DIGITS);
      
      Print("--- Roll-Off activo ---");
      Print("Posiciones: ", posicionesAbiertas);
      
      bool estadoNeutralizado = g_orden_neutralizadora_activada || VerificarNeutralizacion();
      Print("Estado: ", (estadoNeutralizado ? "NEUTRALIZADO" : "NO neutralizado"));
      
      if(estadoNeutralizado)
      {
         Print("Acción: Esperando nuevo umbral de ", g_ticks_umbral_roll_off, " ticks");
         Print("Precio referencia: ", DoubleToString(g_precio_activacion_roll_off, digits));
      }
      else
      {
         for(int i = 0; i < PositionsTotal(); i++)
         {
            if(posInfo.SelectByIndex(i))
            {
               if(posInfo.Magic() == g_numero_magico && posInfo.Symbol() == _Symbol)
               {
                  double tp = posInfo.TakeProfit();
                  if(tp != 0)
                  {
                     Print("TP fijo: ", DoubleToString(tp, digits));
                     break;
                  }
               }
            }
         }
         Print("Acción: Esperando TP o activación orden protección");
      }
      
      ultimoReporte = TimeCurrent();
   }
}

//+------------------------------------------------------------------+
//| Gestionar sistema Roll-Off                                      |
//+------------------------------------------------------------------+
void GestionarSistemaRollOff()
{
   if(!g_sistema_activo) return;
   
   if(g_nivel_actual < g_nivel_activacion_cierre)
      return;
   
   bool hayNeutralizacion = g_orden_neutralizadora_activada || VerificarNeutralizacion();
   
   // PRIMERA ACTIVACIÓN
   if(!g_roll_off_activo && hayNeutralizacion)
   {
      g_roll_off_activo = true;
      
      double precioUltimaEntrada = 0;
      CPositionInfo posInfo;
      
      for(int i = 0; i < PositionsTotal(); i++)
      {
         if(posInfo.SelectByIndex(i))
         {
            if(posInfo.Magic() == g_numero_magico && posInfo.Symbol() == _Symbol)
            {
               string comentario = posInfo.Comment();
               int nivel = 0;
               
               if(StringFind(comentario, "Nivel_") >= 0)
               {
                  nivel = (int)StringToInteger(StringSubstr(comentario, 6));
               }
               
               if(nivel >= g_nivel_actual)
               {
                  precioUltimaEntrada = posInfo.PriceOpen();
               }
            }
         }
      }
      
      g_precio_activacion_roll_off = precioUltimaEntrada;
      
      Print("========================================");
      Print(">>> SISTEMA ROLL-OFF ACTIVADO <<<");
      Print(">>> PRIMERA NEUTRALIZACIÓN DETECTADA");
      Print(">>> Nivel: ", g_nivel_actual);
      Print(">>> Precio referencia: ", DoubleToString(g_precio_activacion_roll_off, _Digits));
      Print("========================================");
      
      CTrade tradeGestion;
      tradeGestion.SetExpertMagicNumber(g_numero_magico);
      
      int tpSlQuitados = 0;
      for(int i = 0; i < PositionsTotal(); i++)
      {
         if(posInfo.SelectByIndex(i))
         {
            if(posInfo.Magic() == g_numero_magico && posInfo.Symbol() == _Symbol)
            {
               ulong ticket = posInfo.Ticket();
               double tp = posInfo.TakeProfit();
               double sl = posInfo.StopLoss();
               
               if(tp != 0 || sl != 0)
               {
                  if(tradeGestion.PositionModify(ticket, 0, 0))
                  {
                     Print("  ✓ TP/SL quitados #", ticket);
                     tpSlQuitados++;
                  }
               }
            }
         }
      }
      
      Print(">>> TP/SL quitados: ", tpSlQuitados);
      Print(">>> Esperando movimiento de ", g_ticks_umbral_roll_off, " ticks");
      Print("========================================");
      
      return;
   }
   
   // GESTIÓN ACTIVA
   if(g_roll_off_activo)
   {
      MonitorearGanadorasRollOff();
      
      bool neutralizacionActiva = g_orden_neutralizadora_activada || VerificarNeutralizacion();
      
      if(neutralizacionActiva)
      {
         double precioActual = (SymbolInfoDouble(_Symbol, SYMBOL_BID) + 
                               SymbolInfoDouble(_Symbol, SYMBOL_ASK)) / 2;
         
         double punto = SymbolInfoDouble(_Symbol, SYMBOL_POINT);
         double movimiento = precioActual - g_precio_activacion_roll_off;
         int ticksMovidos = (int)MathRound(movimiento / punto);
         
         bool umbralAlcanzado = (MathAbs(ticksMovidos) >= g_ticks_umbral_roll_off);
         
         if(umbralAlcanzado && (TimeCurrent() - g_ultimo_roll_off) > 60)
         {
            Print("========================================");
            Print(">>> UMBRAL ALCANZADO <<<");
            Print(">>> Movimiento: ", MathAbs(ticksMovidos), " ticks");
            Print(">>> Precio referencia: ", DoubleToString(g_precio_activacion_roll_off, _Digits));
            Print(">>> Precio actual: ", DoubleToString(precioActual, _Digits));
            Print(">>> Ejecutando Roll-Off...");
            Print("========================================");
            
            bool exito = EjecutarRollOff();
            
            if(exito)
            {
               Print(">>> Roll-Off completado");
               Print(">>> Nuevo precio referencia establecido");
               
               g_orden_neutralizadora_activada = false;
            }
         }
         
         static int contadorTicks = 0;
         contadorTicks++;
         if(contadorTicks >= 100)
         {
            Print("--- Roll-Off activo ---");
            Print("Estado: NEUTRALIZADO");
            Print("Movimiento desde referencia: ", ticksMovidos, " ticks");
            Print("Umbral: ", g_ticks_umbral_roll_off, " ticks");
            Print("Restante: ", (g_ticks_umbral_roll_off - MathAbs(ticksMovidos)), " ticks");
            contadorTicks = 0;
         }
      }
      else
      {
         // ========== PASO 7: RECALCULAR TP SI ESTÁ CERCA ==========
         double tpActual = 0;
         ENUM_POSITION_TYPE tipoGanadoras = POSITION_TYPE_BUY;
         
         CPositionInfo posInfoPaso7;
         for(int i = 0; i < PositionsTotal(); i++)
         {
            if(posInfoPaso7.SelectByIndex(i))
            {
               if(posInfoPaso7.Magic() == g_numero_magico && posInfoPaso7.Symbol() == _Symbol)
               {
                  tpActual = posInfoPaso7.TakeProfit();
                  tipoGanadoras = posInfoPaso7.PositionType();
                  
                  if(tpActual != 0)
                     break;
               }
            }
         }
         
         if(tpActual != 0)
         {
            double precioActual;
            if(tipoGanadoras == POSITION_TYPE_BUY)
               precioActual = SymbolInfoDouble(_Symbol, SYMBOL_BID);
            else
               precioActual = SymbolInfoDouble(_Symbol, SYMBOL_ASK);
            
            double punto = SymbolInfoDouble(_Symbol, SYMBOL_POINT);
            double distancia = MathAbs(tpActual - precioActual);
            int ticksHastaTP = (int)MathRound(distancia / punto);
            
            static datetime ultimoRecalculo = 0;
            
            if(ticksHastaTP <= 10 && ticksHastaTP > 0 && (TimeCurrent() - ultimoRecalculo) > 60)
            {
               Print("========================================");
               Print(">>> PASO 7: RECALCULAR TP <<<");
               Print(">>> TP está cerca: ", ticksHastaTP, " ticks");
               Print(">>> Ejecutando Roll-Off para recalcular");
               Print("========================================");
               
               bool exito = EjecutarRollOff();
               
               if(exito)
               {
                  Print(">>> TP recalculado con swap actualizado");
                  ultimoRecalculo = TimeCurrent();
               }
            }
            
            static int contadorPaso7 = 0;
            contadorPaso7++;
            if(contadorPaso7 >= 100 && ticksHastaTP > 21)
            {
               Print("--- Paso 7 ---");
               Print("Distancia al TP: ", ticksHastaTP, " ticks");
               Print("Umbral recálculo: 21 ticks");
               contadorPaso7 = 0;
            }
         }
         
         static datetime ultimoReporteNoNeutralizado = 0;
         if(TimeCurrent() - ultimoReporteNoNeutralizado > 30)
         {
            Print("--- Roll-Off activo ---");
            Print("Estado: NO neutralizado");
            Print("Acción: Esperando TP o activación orden protección");
            Print("NO se cuentan ticks en este estado");
            ultimoReporteNoNeutralizado = TimeCurrent();
         }
      }
   }
}

