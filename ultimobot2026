   GlobalVariableDel(prefijo + "ORDEN_NEUTRA");
   
   string prefijoPanel = "EA_PANEL_" + _Symbol + "_";
   GlobalVariableDel(prefijoPanel + "LOTE");
   GlobalVariableDel(prefijoPanel + "TP1");
   GlobalVariableDel(prefijoPanel + "TP2");
   GlobalVariableDel(prefijoPanel + "DIST");
   GlobalVariableDel(prefijoPanel + "CIERRE");
   GlobalVariableDel(prefijoPanel + "GANANCIA");
}

//+------------------------------------------------------------------+
//| Función de inicialización del Expert Advisor                     |
//+------------------------------------------------------------------+
int OnInit()
{
   trade.SetExpertMagicNumber(g_numero_magico);
   
   // Intentar restaurar estado si viene de cambio de temporalidad
   g_estado_restaurado = RestaurarEstadoCompleto();
   
   if(!g_estado_restaurado)
   {
      // ========== Inicialización NORMAL (primera vez) ==========
      g_roll_off_activo = false;
      g_precio_activacion_roll_off = 0;
      g_ticks_umbral_roll_off = 77;
      g_ultimo_roll_off = 0;
      
      Print("========================================");
      Print("Sistema Roll-Off inicializado (NUEVO)");
      Print("Umbral movimiento: ", g_ticks_umbral_roll_off, " ticks (", 
            g_ticks_umbral_roll_off/10, " pips)");
      Print("========================================");
   }
   
   // Crear panel (siempre se recrea visualmente)
   if(!DialogoExterno.Create(0, "CoberturaEspecial", 0, 50, 50, 300, 350))
      return(INIT_FAILED);
   
   if(!DialogoExterno.Run())
      return(INIT_FAILED);
   
   // Si viene de cambio de temporalidad, restaurar valores del panel
   if(g_estado_restaurado)
   {
      DialogoExterno.RestaurarValoresPanel();
      Print(">>> Estado restaurado exitosamente tras cambio de temporalidad");
   }
   
   ChartRedraw();
   return(INIT_SUCCEEDED);
}

//+------------------------------------------------------------------+
//| Función de desinicialización del Expert Advisor                  |
//+------------------------------------------------------------------+
void OnDeinit(const int reason)
{
   Print(">>> OnDeinit - Razón: ", reason);
   
   if(reason == REASON_CHARTCHANGE)
   {
      // ========== CAMBIO DE TEMPORALIDAD ==========
      // Guardar estado completo del sistema
      GuardarEstadoCompleto();
      
      // Guardar valores del panel (lo que el usuario ve en pantalla)
      DialogoExterno.GuardarValoresPanel();
      
      Print(">>> Todo guardado - Listo para restaurar en nueva temporalidad");
   }
   else
   {
      // ========== CIERRE NORMAL / ELIMINACIÓN DEL EA ==========
      // Limpiar todas las GlobalVariables
      LimpiarGlobalVariables();
      Print(">>> GlobalVariables limpiadas (no fue cambio de temporalidad)");
   }
   
   // Destruir panel siempre (MT5 lo requiere)
   DialogoExterno.Destroy(reason);
}

