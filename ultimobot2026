//| NUEVO: Guardar valores del panel en GlobalVariables              |
//+------------------------------------------------------------------+
void CPanelTrading::GuardarValoresPanel()
{
   string prefijo = "EA_PANEL_" + _Symbol + "_";
   
   // Leer valores actuales de los campos Edit del panel
   double lote = StringToDouble(m_entrada_lote.Text());
   double tp1 = StringToDouble(m_entrada_tp1.Text());
   double tp2 = StringToDouble(m_entrada_tp2.Text());
   double dist = StringToDouble(m_entrada_dist.Text());
   double cierre = StringToDouble(m_entrada_cierre.Text());
   double ganancia = StringToDouble(m_entrada_ganancia.Text());
   
   // Guardar en GlobalVariables del terminal
   GlobalVariableSet(prefijo + "LOTE", lote);
   GlobalVariableSet(prefijo + "TP1", tp1);
   GlobalVariableSet(prefijo + "TP2", tp2);
   GlobalVariableSet(prefijo + "DIST", dist);
   GlobalVariableSet(prefijo + "CIERRE", cierre);
   GlobalVariableSet(prefijo + "GANANCIA", ganancia);
   
   Print(">>> Panel guardado - Lote:", DoubleToString(lote, 2),
         " TP1:", DoubleToString(tp1, 0),
         " TP2:", DoubleToString(tp2, 0),
         " Dist:", DoubleToString(dist, 0),
         " Cierre:", DoubleToString(cierre, 0),
         " GananciaM:", DoubleToString(ganancia, 2));
}

//+------------------------------------------------------------------+
//| NUEVO: Restaurar valores del panel desde GlobalVariables         |
//+------------------------------------------------------------------+
void CPanelTrading::RestaurarValoresPanel()
{
   string prefijo = "EA_PANEL_" + _Symbol + "_";
   
   // Verificar si existen valores guardados
   if(!GlobalVariableCheck(prefijo + "LOTE"))
   {
      Print(">>> No hay valores de panel guardados");
      return;
   }
   
   // Leer valores desde GlobalVariables
   double lote = GlobalVariableGet(prefijo + "LOTE");
   double tp1 = GlobalVariableGet(prefijo + "TP1");
   double tp2 = GlobalVariableGet(prefijo + "TP2");
   double dist = GlobalVariableGet(prefijo + "DIST");
   double cierre = GlobalVariableGet(prefijo + "CIERRE");
   double ganancia = GlobalVariableGet(prefijo + "GANANCIA");
   
   // Aplicar a los campos del panel
   m_entrada_lote.Text(DoubleToString(lote, 2));
   m_entrada_tp1.Text(IntegerToString((int)tp1));
   m_entrada_tp2.Text(IntegerToString((int)tp2));
   m_entrada_dist.Text(IntegerToString((int)dist));
   m_entrada_cierre.Text(IntegerToString((int)cierre));
   m_entrada_ganancia.Text(DoubleToString(ganancia, 2));
   
   // Limpiar las GlobalVariables del panel
   GlobalVariableDel(prefijo + "LOTE");
   GlobalVariableDel(prefijo + "TP1");
   GlobalVariableDel(prefijo + "TP2");
   GlobalVariableDel(prefijo + "DIST");
   GlobalVariableDel(prefijo + "CIERRE");
   GlobalVariableDel(prefijo + "GANANCIA");
   
   Print(">>> Panel restaurado - Lote:", DoubleToString(lote, 2),
         " TP1:", DoubleToString(tp1, 0),
         " TP2:", DoubleToString(tp2, 0),
         " Dist:", DoubleToString(dist, 0),
         " Cierre:", DoubleToString(cierre, 0),
         " GananciaM:", DoubleToString(ganancia, 2));
}

