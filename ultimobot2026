   GlobalVariableSet(prefijo + "LOTE_INICIAL", g_lote_inicial);
   GlobalVariableSet(prefijo + "TP1_TICKS", g_tp1_ticks);
   GlobalVariableSet(prefijo + "TP2_TICKS", g_tp2_ticks);
   GlobalVariableSet(prefijo + "DIST_TICKS", g_distancia_ticks);
   GlobalVariableSet(prefijo + "NIVEL_CIERRE", (double)g_nivel_activacion_cierre);
   GlobalVariableSet(prefijo + "GANANCIA_OBJ", g_ganancia_objetivo);
   
   // --- Precios de cobertura ---
   GlobalVariableSet(prefijo + "COB_E1", g_precio_cobertura_E1);
   GlobalVariableSet(prefijo + "COB_E2", g_precio_cobertura_E2);
   GlobalVariableSet(prefijo + "COB1_FIJO", g_precio_cobertura1_fijo);
   GlobalVariableSet(prefijo + "COB2_FIJO", g_precio_cobertura2_fijo);
   
   // --- Estado Roll-Off ---
   GlobalVariableSet(prefijo + "ROLLOFF_ACTIVO", g_roll_off_activo ? 1.0 : 0.0);
   GlobalVariableSet(prefijo + "ROLLOFF_PRECIO", g_precio_activacion_roll_off);
   GlobalVariableSet(prefijo + "ROLLOFF_UMBRAL", (double)g_ticks_umbral_roll_off);
   GlobalVariableSet(prefijo + "ROLLOFF_ULTIMO", (double)g_ultimo_roll_off);
   GlobalVariableSet(prefijo + "TIEMPO_1RA", (double)g_tiempo_primera_entrada);
   GlobalVariableSet(prefijo + "ORDEN_NEUTRA", g_orden_neutralizadora_activada ? 1.0 : 0.0);
   
   // --- Marca de cambio de temporalidad ---
   GlobalVariableSet(prefijo + "CAMBIO_TF", 1.0);
   
   Print(">>> Estado completo GUARDADO para cambio de temporalidad");
}

bool RestaurarEstadoCompleto()
{
   string prefijo = "EA_STATE_" + _Symbol + "_";
   
   if(!GlobalVariableCheck(prefijo + "CAMBIO_TF"))
      return false;
   
   double esCambioTF = GlobalVariableGet(prefijo + "CAMBIO_TF");
   if(esCambioTF != 1.0)
      return false;
   
   Print("========================================");
   Print(">>> CAMBIO DE TEMPORALIDAD DETECTADO <<<");
   Print(">>> Restaurando estado completo...");
   Print("========================================");
   
   // --- Restaurar estado del sistema ---
   g_sistema_activo = (GlobalVariableGet(prefijo + "ACTIVO") == 1.0);
   g_tipo_inicial = (ENUM_ORDER_TYPE)(int)GlobalVariableGet(prefijo + "TIPO_INICIAL");
   g_nivel_actual = (int)GlobalVariableGet(prefijo + "NIVEL_ACTUAL");
   g_precio_entrada1 = GlobalVariableGet(prefijo + "PRECIO_E1");
   g_precio_entrada2 = GlobalVariableGet(prefijo + "PRECIO_E2");
   g_lote_inicial = GlobalVariableGet(prefijo + "LOTE_INICIAL");
   g_tp1_ticks = GlobalVariableGet(prefijo + "TP1_TICKS");
   g_tp2_ticks = GlobalVariableGet(prefijo + "TP2_TICKS");
   g_distancia_ticks = GlobalVariableGet(prefijo + "DIST_TICKS");
   g_nivel_activacion_cierre = (int)GlobalVariableGet(prefijo + "NIVEL_CIERRE");
   g_ganancia_objetivo = GlobalVariableGet(prefijo + "GANANCIA_OBJ");
   
   // --- Precios de cobertura ---
   g_precio_cobertura_E1 = GlobalVariableGet(prefijo + "COB_E1");
   g_precio_cobertura_E2 = GlobalVariableGet(prefijo + "COB_E2");
   g_precio_cobertura1_fijo = GlobalVariableGet(prefijo + "COB1_FIJO");
   g_precio_cobertura2_fijo = GlobalVariableGet(prefijo + "COB2_FIJO");
   
   // --- Estado Roll-Off ---
   g_roll_off_activo = (GlobalVariableGet(prefijo + "ROLLOFF_ACTIVO") == 1.0);
   g_precio_activacion_roll_off = GlobalVariableGet(prefijo + "ROLLOFF_PRECIO");
   g_ticks_umbral_roll_off = (int)GlobalVariableGet(prefijo + "ROLLOFF_UMBRAL");
   g_ultimo_roll_off = (datetime)(int)GlobalVariableGet(prefijo + "ROLLOFF_ULTIMO");
   g_tiempo_primera_entrada = (datetime)(int)GlobalVariableGet(prefijo + "TIEMPO_1RA");
   g_orden_neutralizadora_activada = (GlobalVariableGet(prefijo + "ORDEN_NEUTRA") == 1.0);
   
   // --- LIMPIAR marca ---
   GlobalVariableDel(prefijo + "CAMBIO_TF");
   
   Print("--- Estado restaurado ---");
   Print("Sistema activo: ", g_sistema_activo);
   Print("Tipo inicial: ", (g_tipo_inicial == ORDER_TYPE_BUY ? "BUY" : "SELL"));
   Print("Nivel actual: ", g_nivel_actual);
   Print("Precio E1: ", DoubleToString(g_precio_entrada1, _Digits));
   Print("Precio E2: ", DoubleToString(g_precio_entrada2, _Digits));
   Print("Roll-Off activo: ", g_roll_off_activo);
   Print("Umbral Roll-Off: ", g_ticks_umbral_roll_off, " ticks");
   Print("========================================");
   
   return true;
}

