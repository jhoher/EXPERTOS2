//+------------------------------------------------------------------+
//| Calcular volúmenes totales BUY y SELL                            |
//+------------------------------------------------------------------+
void CalcularVolumenesTotales(double &volumenBuyTotal, double &volumenSellTotal)
{
   volumenBuyTotal = 0;
   volumenSellTotal = 0;
   
   CPositionInfo posInfo;
   
   for(int i = 0; i < PositionsTotal(); i++)
   {
      if(posInfo.SelectByIndex(i))
      {
         if(posInfo.Magic() == g_numero_magico && posInfo.Symbol() == _Symbol)
         {
            double volumen = posInfo.Volume();
            string comentario = posInfo.Comment();
            int nivel = 0;
            
            if(StringFind(comentario, "Nivel_") >= 0)
            {
               nivel = (int)StringToInteger(StringSubstr(comentario, 6));
            }
            
            ENUM_ORDER_TYPE tipoReal;
            if(nivel % 2 == 1)
               tipoReal = g_tipo_inicial;
            else
               tipoReal = (g_tipo_inicial == ORDER_TYPE_BUY) ? ORDER_TYPE_SELL : ORDER_TYPE_BUY;
            
            if(tipoReal == ORDER_TYPE_BUY)
               volumenBuyTotal += volumen;
            else
               volumenSellTotal += volumen;
         }
      }
   }
}

//+------------------------------------------------------------------+
//| Verificar si hay neutralización de volúmenes                     |
//+------------------------------------------------------------------+
bool VerificarNeutralizacion()
{
   double volBuy = 0, volSell = 0;
   CalcularVolumenesTotales(volBuy, volSell);
   
   if(volBuy == 0 || volSell == 0)
      return false;
   
   double diferencia = MathAbs(volBuy - volSell);
   double minVol = SymbolInfoDouble(_Symbol, SYMBOL_VOLUME_MIN);
   
   return (diferencia < minVol * 2);
}

//+------------------------------------------------------------------+
//| Calcular P&L actual de todas las posiciones                      |
//+------------------------------------------------------------------+
double CalcularPLTotal()
{
   double plTotal = 0;
   CPositionInfo posInfo;
   
   for(int i = 0; i < PositionsTotal(); i++)
   {
      if(posInfo.SelectByIndex(i))
      {
         if(posInfo.Magic() == g_numero_magico && posInfo.Symbol() == _Symbol)
         {
            plTotal += posInfo.Profit() + posInfo.Swap() + posInfo.Commission();
         }
      }
   }
   
   return plTotal;
}

//+------------------------------------------------------------------+
//| Calcular P&L separado por tipo (BUY/SELL)                        |
//+------------------------------------------------------------------+
void CalcularPLPorTipo(double &plBuy, double &plSell)
{
   plBuy = 0;
   plSell = 0;
   
   CPositionInfo posInfo;
   
   for(int i = 0; i < PositionsTotal(); i++)
   {
      if(posInfo.SelectByIndex(i))
      {
         if(posInfo.Magic() == g_numero_magico && posInfo.Symbol() == _Symbol)
         {
            double pl = posInfo.Profit() + posInfo.Swap() + posInfo.Commission();
            
            if(posInfo.PositionType() == POSITION_TYPE_BUY)
               plBuy += pl;
            else
               plSell += pl;
         }
      }
   }
}

//+------------------------------------------------------------------+
//| Detectar si el mercado está en TENDENCIA o RANGO con ADX (M5)    |
//+------------------------------------------------------------------+
int DetectarCondicionMercado()
{
   Print("========================================");
   Print(">>> DETECTANDO CONDICIÓN DEL MERCADO <<<");
   
   // Regla de contradicción
   if(g_contador_rolloff > 0 && g_modo_rolloff == 1)
   {
      Print(">>> REGLA DE CONTRADICCIÓN ACTIVADA <<<");
      Print(">>> Último Roll-Off: CIERRA PERDEDORAS");
      Print(">>> Pero el mercado neutralizó de nuevo");
      Print(">>> El precio se devolvió → NO era tendencia");
      Print(">>> FORZANDO: CIERRA GANADORAS (rango confirmado)");
      Print("========================================");
      return 0;
   }
   
   if(g_handle_adx == INVALID_HANDLE)
   {
      g_handle_adx = iADX(_Symbol, PERIOD_M5, 14);
      
      if(g_handle_adx == INVALID_HANDLE)
      {
         Print(">>> ERROR: No se pudo crear indicador ADX");
         Print(">>> Usando alternancia como respaldo");
         return -1;
      }
      
      Print(">>> Handle ADX creado (M5): ", g_handle_adx);
   }
   
   double adxBuffer[];
   ArraySetAsSeries(adxBuffer, true);
   double plusDI[];
   double minusDI[];
   ArraySetAsSeries(plusDI, true);
   ArraySetAsSeries(minusDI, true);
   
   int copiados = CopyBuffer(g_handle_adx, 0, 0, 3, adxBuffer);
   int copiadosPDI = CopyBuffer(g_handle_adx, 1, 0, 3, plusDI);
   int copiadosMDI = CopyBuffer(g_handle_adx, 2, 0, 3, minusDI);
   
   if(copiados < 3 || copiadosPDI < 3 || copiadosMDI < 3)
   {
      Print(">>> ERROR: No se pudieron copiar datos del ADX");
      return -1;
   }
   
   double adxActual = adxBuffer[0];
   double adxAnterior = adxBuffer[1];
   double pdiActual = plusDI[0];
   double mdiActual = minusDI[0];
   
   Print("ADX actual (M5): ", DoubleToString(adxActual, 1));
   Print("ADX anterior: ", DoubleToString(adxAnterior, 1));
   Print("+DI: ", DoubleToString(pdiActual, 1), " | -DI: ", DoubleToString(mdiActual, 1));
   
   int decision;
   string razon;
   
   if(adxActual > 25)
   {
      decision = 1;
      razon = "TENDENCIA (ADX=" + DoubleToString(adxActual, 1) + " > 25)";
      
      if(pdiActual > mdiActual)
         Print(">>> Dirección tendencia: ALCISTA (+DI > -DI)");
      else
         Print(">>> Dirección tendencia: BAJISTA (-DI > +DI)");
   }
   else if(adxActual < 20)
   {
      decision = 0;
      razon = "RANGO (ADX=" + DoubleToString(adxActual, 1) + " < 20)";
   }
   else
   {
      decision = -1;
      razon = "ZONA GRIS (ADX=" + DoubleToString(adxActual, 1) + " entre 20-25)";
   }
   
   Print(">>> DECISIÓN: ", razon);
   
   if(decision == -1 && adxActual > adxAnterior && (adxActual - adxAnterior) > 3)
   {
      decision = 1;
      Print(">>> CORRECCIÓN: ADX subiendo rápido (+",
            DoubleToString(adxActual - adxAnterior, 1),
            ") → TENDENCIA emergente");
   }
   
   Print("========================================");
   return decision;
}


// ================================================================
// EjecutarRollOff - Sin cambios respecto a la versión original
// (la lógica de qué cerrar/qué TP poner sigue siendo la misma,
//  solo cambió QUIÉN dispara esta función: ahora es la estructura M3+M1)
// ================================================================
bool EjecutarRollOff()
{
   int condicionMercado = DetectarCondicionMercado();
   
   if(condicionMercado == 0)
   {
      g_modo_rolloff = 0;
      Print(">>> MODO ROLL-OFF: CIERRA GANADORAS (mercado en RANGO)");
   }
   else if(condicionMercado == 1)
   {
      g_modo_rolloff = 1;
      Print(">>> MODO ROLL-OFF: CIERRA PERDEDORAS (mercado en TENDENCIA)");
   }
   else
   {
      if(g_contador_rolloff % 2 == 0)
         g_modo_rolloff = 0;
      else
         g_modo_rolloff = 1;
      
      Print(">>> MODO ROLL-OFF: ALTERNANCIA (zona gris ADX)");
      Print(">>> Ciclo #", g_contador_rolloff, " → ",
            (g_modo_rolloff == 0 ? "CIERRA GANADORAS" : "CIERRA PERDEDORAS"));
   }
   
   g_contador_rolloff++;
   
   Print("========================================");
   Print("========== EJECUTANDO ROLL-OFF #", g_contador_rolloff, " ==========");
   Print(">>> MODO: ", (g_modo_rolloff == 0 ? "CIERRA GANADORAS" : "CIERRA PERDEDORAS"));
   
   CTrade tradeRollOff;
   CPositionInfo posInfo;
   tradeRollOff.SetExpertMagicNumber(g_numero_magico);
   
   double plBuy = 0, plSell = 0;
   CalcularPLPorTipo(plBuy, plSell);
   
   Print("P&L BUY: ", DoubleToString(plBuy, 2), " | P&L SELL: ", DoubleToString(plSell, 2));
   
   bool buyGanando = (plBuy > plSell);
   Print("Lado ganador: ", (buyGanando ? "BUY" : "SELL"));
   Print("Lado perdedor: ", (buyGanando ? "SELL" : "BUY"));
   
   double punto = SymbolInfoDouble(_Symbol, SYMBOL_POINT);
   int digits = (int)SymbolInfoInteger(_Symbol, SYMBOL_DIGITS);
   
   double precioActualAntesCierre;
   if(buyGanando)
      precioActualAntesCierre = SymbolInfoDouble(_Symbol, SYMBOL_BID);
   else
      precioActualAntesCierre = SymbolInfoDouble(_Symbol, SYMBOL_ASK);
   
   Print("Precio actual (referencia): ", DoubleToString(precioActualAntesCierre, digits));
   
   // PASO 0: Leer swap de todas
   Print(">>> PASO 0: LEER SWAP DE TODAS LAS POSICIONES <<<");
   double swapTotalTodasAbiertas = 0;
   
   for(int i = 0; i < PositionsTotal(); i++)
   {
      if(posInfo.SelectByIndex(i))
      {
         if(posInfo.Magic() == g_numero_magico && posInfo.Symbol() == _Symbol)
         {
            ulong ticket = posInfo.Ticket();
            double swapPos = posInfo.Swap();
            ENUM_POSITION_TYPE tipoPosicion = posInfo.PositionType();
            string comentario = posInfo.Comment();
            
            Print("  Pos #", ticket,
                  " Tipo:", (tipoPosicion == POSITION_TYPE_BUY ? "BUY" : "SELL"),
                  " Com:", comentario,
                  " Swap: ", DoubleToString(swapPos, 2));
            
            swapTotalTodasAbiertas += swapPos;
         }
      }
   }
   
   Print("SWAP TOTAL TODAS ABIERTAS: ", DoubleToString(swapTotalTodasAbiertas, 2));
   
   // PASO 1: Cerrar según modo
   Print("========================================");
   bool cerrarGanadoras = (g_modo_rolloff == 0);
   
   if(cerrarGanadoras)
      Print(">>> PASO 1: CERRANDO GANADORAS <<<");
   else
      Print(">>> PASO 1: CERRANDO PERDEDORAS <<<");
   
   ulong ticketsCerrar[];
   int contadorTickets = 0;
   double volumenTotalCerradas = 0;
   
   for(int i = PositionsTotal() - 1; i >= 0; i--)
   {
      if(posInfo.SelectByIndex(i))
      {
         if(posInfo.Magic() == g_numero_magico && posInfo.Symbol() == _Symbol)
         {
            ENUM_POSITION_TYPE tipoPosicion = posInfo.PositionType();
            
            bool esGanadora = false;
            if(buyGanando)
               esGanadora = (tipoPosicion == POSITION_TYPE_BUY);
            else
               esGanadora = (tipoPosicion == POSITION_TYPE_SELL);
            
            bool debeCerrar = false;
            if(cerrarGanadoras)
               debeCerrar = esGanadora;
            else
               debeCerrar = !esGanadora;
            
            if(debeCerrar)
            {
               ulong ticket = posInfo.Ticket();
               double volumen = posInfo.Volume();
               string comentario = posInfo.Comment();
               
               Print("  ", (cerrarGanadoras ? "GANADORA" : "PERDEDORA"),
                     " #", ticket,
                     " Vol:", DoubleToString(volumen, 2),
                     " Tipo:", (tipoPosicion == POSITION_TYPE_BUY ? "BUY" : "SELL"),
                     " Com:", comentario, " → SE CERRARÁ");
               
               ArrayResize(ticketsCerrar, contadorTickets + 1);
               ticketsCerrar[contadorTickets] = ticket;
               contadorTickets++;
               volumenTotalCerradas += volumen;
            }
            else
            {
               ulong ticket = posInfo.Ticket();
               double volumen = posInfo.Volume();
               string comentario = posInfo.Comment();
               
               Print("  ", (cerrarGanadoras ? "PERDEDORA" : "GANADORA"),
                     " #", ticket,
                     " Vol:", DoubleToString(volumen, 2),
                     " Tipo:", (tipoPosicion == POSITION_TYPE_BUY ? "BUY" : "SELL"),
                     " Com:", comentario, " → QUEDA ABIERTA");
            }
         }
      }
   }
   
   Print("----------------------------------------------");
   Print("Posiciones a cerrar: ", contadorTickets);
   Print("Volumen cerrado: ", DoubleToString(volumenTotalCerradas, 2));
   
   for(int i = 0; i < contadorTickets; i++)
   {
      ulong ticket = ticketsCerrar[i];
      if(tradeRollOff.PositionClose(ticket))
      {
         Print("  ✓ Cerrada #", ticket);
         Sleep(100);
      }
   }
   
   Sleep(200);
   
   // Leer profit de cerradas
   Print("--- Leyendo TODA la secuencia desde inicio ---");
   double profitTodasCerradas = 0;
   double swapTodasCerradas = 0;
   int cantidadCerradas = 0;
   
   datetime desde = g_tiempo_primera_entrada;
   datetime hasta = TimeCurrent();
   
   if(HistorySelect(desde, hasta))
   {
      int totalDeals = HistoryDealsTotal();
      
      for(int i = totalDeals - 1; i >= 0; i--)
      {
         ulong dealTicket = HistoryDealGetTicket(i);
         
         if(dealTicket > 0)
         {
            long magic = HistoryDealGetInteger(dealTicket, DEAL_MAGIC);
            string symbol = HistoryDealGetString(dealTicket, DEAL_SYMBOL);
            long dealEntry = HistoryDealGetInteger(dealTicket, DEAL_ENTRY);
            
            if(magic == g_numero_magico && symbol == _Symbol && dealEntry == DEAL_ENTRY_OUT)
            {
               double profitReal = HistoryDealGetDouble(dealTicket, DEAL_PROFIT);
               double swapReal = HistoryDealGetDouble(dealTicket, DEAL_SWAP);
               double volumen = HistoryDealGetDouble(dealTicket, DEAL_VOLUME);
               ulong positionTicket = HistoryDealGetInteger(dealTicket, DEAL_POSITION_ID);
               
               Print("  Deal #", dealTicket, " Pos #", positionTicket);
               Print("    Profit: ", DoubleToString(profitReal, 2));
               Print("    Swap: ", DoubleToString(swapReal, 2));
               Print("    Volumen: ", DoubleToString(volumen, 2));
               
               profitTodasCerradas += profitReal;
               swapTodasCerradas += swapReal;
               cantidadCerradas++;
            }
         }
      }
   }
   
   Print("----------------------------------------------");
   Print("Total cerradas: ", cantidadCerradas);
   Print("PROFIT CERRADAS: ", DoubleToString(profitTodasCerradas, 2));
   
   // Posiciones abiertas restantes
   Print("--- Posiciones que quedan abiertas ---");
   double swapAbiertas = 0;
   int cantidadAbiertas = 0;
   double volumenTotalAbiertas = 0;
   ENUM_POSITION_TYPE tipoAbiertasMT5 = POSITION_TYPE_BUY;
   ENUM_ORDER_TYPE tipoAbiertas = ORDER_TYPE_BUY;
   
   for(int i = 0; i < PositionsTotal(); i++)
   {
      if(posInfo.SelectByIndex(i))
      {
         if(posInfo.Magic() == g_numero_magico && posInfo.Symbol() == _Symbol)
         {
            double swapPos = posInfo.Swap();
            ulong ticket = posInfo.Ticket();
            double volumen = posInfo.Volume();
            
            Print("  Abierta #", ticket, ": Swap=", DoubleToString(swapPos, 2));
            
            swapAbiertas += swapPos;
            volumenTotalAbiertas += volumen;
            tipoAbiertasMT5 = posInfo.PositionType();
            tipoAbiertas = (tipoAbiertasMT5 == POSITION_TYPE_BUY) ? ORDER_TYPE_BUY : ORDER_TYPE_SELL;
            cantidadAbiertas++;
         }
      }
   }
   
   Print("Total abiertas: ", cantidadAbiertas);
   Print("Volumen total abiertas: ", DoubleToString(volumenTotalAbiertas, 2));
   Print("SWAP ABIERTAS: ", DoubleToString(swapAbiertas, 2));
   
   if(cantidadAbiertas == 0)
   {
      Print("✗ ERROR: No hay posiciones abiertas después del cierre");
      return false;
   }
   
   // Swap total real
   double swapDealsAnteriores = 0;
   
   if(HistorySelect(desde, hasta))
   {
      int totalDeals = HistoryDealsTotal();
      for(int i = totalDeals - 1; i >= 0; i--)
      {
         ulong dealTicket = HistoryDealGetTicket(i);
         if(dealTicket > 0)
         {
            long magic = HistoryDealGetInteger(dealTicket, DEAL_MAGIC);
            string symbol = HistoryDealGetString(dealTicket, DEAL_SYMBOL);
            long dealEntry = HistoryDealGetInteger(dealTicket, DEAL_ENTRY);
            datetime dealTime = (datetime)HistoryDealGetInteger(dealTicket, DEAL_TIME);
            
            if(magic == g_numero_magico && symbol == _Symbol && dealEntry == DEAL_ENTRY_OUT)
            {
               if(dealTime < TimeCurrent() - 5)
               {
                  double swapDeal = HistoryDealGetDouble(dealTicket, DEAL_SWAP);
                  swapDealsAnteriores += swapDeal;
               }
            }
         }
      }
   }
   
   double swapTotalReal = swapTotalTodasAbiertas + swapDealsAnteriores;
   Print("SWAP TOTAL REAL: ", DoubleToString(swapTotalReal, 2));
   
   // PASO 2: Comisiones totales
   Print(">>> PASO 2: COMISIONES TOTALES <<<");
   double comisionesTotales = 0;
   
   if(HistorySelect(desde, hasta))
   {
      int totalDeals = HistoryDealsTotal();
      for(int i = totalDeals - 1; i >= 0; i--)
      {
         ulong dealTicket = HistoryDealGetTicket(i);
         if(dealTicket > 0)
         {
            long magic = HistoryDealGetInteger(dealTicket, DEAL_MAGIC);
            string symbol = HistoryDealGetString(dealTicket, DEAL_SYMBOL);
            long dealEntry = HistoryDealGetInteger(dealTicket, DEAL_ENTRY);
            
            if(magic == g_numero_magico && symbol == _Symbol && dealEntry == DEAL_ENTRY_OUT)
            {
               double volumen = HistoryDealGetDouble(dealTicket, DEAL_VOLUME);
               double comision = CalcularComisionPepperstone(volumen, _Symbol);
               comisionesTotales += comision;
            }
         }
      }
   }
   
   for(int i = 0; i < PositionsTotal(); i++)
   {
      if(posInfo.SelectByIndex(i))
      {
         if(posInfo.Magic() == g_numero_magico && posInfo.Symbol() == _Symbol)
         {
            double volumen = posInfo.Volume();
            double comision = CalcularComisionPepperstone(volumen, _Symbol);
            comisionesTotales += comision;
         }
      }
   }
   
   Print("COMISIONES TOTALES: ", DoubleToString(comisionesTotales, 2));
   
   // PASO 3: P&L realizado
   Print(">>> PASO 3: P&L REALIZADO <<<");
   double plRealizado = profitTodasCerradas + swapTotalReal - comisionesTotales;
   
   Print("PROFIT CERRADAS: ", DoubleToString(profitTodasCerradas, 2));
   Print("SWAP TOTAL REAL: ", DoubleToString(swapTotalReal, 2), " (incluye abiertas y cerradas)");
   Print("COMISIONES: -", DoubleToString(comisionesTotales, 2));
   Print("P&L REALIZADO: ", DoubleToString(plRealizado, 2));
   
   // ========== Según modo: calcular TP o dejar correr ==========
   if(cerrarGanadoras)
   {
      // MODO CIERRA GANADORAS: Calcular TP para las perdedoras que quedan
      Print("========================================");
      Print(">>> CALCULANDO TP PARA POSICIONES ABIERTAS (PERDEDORAS) <<<");
      
      COrderInfo ordInfo;
      for(int i = OrdersTotal() - 1; i >= 0; i--)
      {
         if(ordInfo.SelectByIndex(i))
         {
            if(ordInfo.Magic() == g_numero_magico && ordInfo.Symbol() == _Symbol)
            {
               string com = ordInfo.Comment();
               if(StringFind(com, "RollOff_Proteccion") >= 0)
                  tradeRollOff.OrderDelete(ordInfo.Ticket());
            }
         }
      }
      
      double sumatoriaPV = 0;
      for(int i = 0; i < PositionsTotal(); i++)
      {
         if(posInfo.SelectByIndex(i))
         {
            if(posInfo.Magic() == g_numero_magico && posInfo.Symbol() == _Symbol)
            {
               sumatoriaPV += posInfo.PriceOpen() * posInfo.Volume();
            }
         }
      }
      
      double precioPromedio = sumatoriaPV / volumenTotalAbiertas;
      Print("Precio promedio apertura perdedoras: ", DoubleToString(precioPromedio, digits));
      
      double valorTickActual = 0;
      bool tickObtenido = false;
      
      double precioActualCalculo;
      if(tipoAbiertas == ORDER_TYPE_BUY)
         precioActualCalculo = SymbolInfoDouble(_Symbol, SYMBOL_BID);
      else
         precioActualCalculo = SymbolInfoDouble(_Symbol, SYMBOL_ASK);
      
      for(int i = 0; i < PositionsTotal(); i++)
      {
         if(posInfo.SelectByIndex(i))
         {
            if(posInfo.Magic() == g_numero_magico && posInfo.Symbol() == _Symbol)
            {
               double volumen = posInfo.Volume();
               double precioApertura = posInfo.PriceOpen();
               double profitActual = posInfo.Profit();
               ENUM_POSITION_TYPE tipoPosicion = posInfo.PositionType();
               
               double difPrecio;
               if(tipoPosicion == POSITION_TYPE_BUY)
                  difPrecio = precioActualCalculo - precioApertura;
               else
                  difPrecio = precioApertura - precioActualCalculo;
               
               double puntosAct = difPrecio / punto;
               
               if(MathAbs(puntosAct) >= 1.0 && MathAbs(profitActual) >= 0.01)
               {
                  valorTickActual = MathAbs(profitActual) / MathAbs(puntosAct) / volumen;
                  Print("  Valor TICK extraído: ", DoubleToString(valorTickActual, 6));
                  tickObtenido = true;
                  break;
               }
            }
         }
      }
      
      if(!tickObtenido || MathAbs(valorTickActual) < 0.1)
         valorTickActual = 0.84;
      
      double profitPerdedoraSimulado = 0;
      for(int i = 0; i < PositionsTotal(); i++)
      {
         if(posInfo.SelectByIndex(i))
         {
            if(posInfo.Magic() == g_numero_magico && posInfo.Symbol() == _Symbol)
            {
               profitPerdedoraSimulado += posInfo.Profit();
            }
         }
      }
      
      Print(">>> SIMULACIÓN: Cierre de perdedora al precio actual <<<");
      Print("Profit perdedora simulado: ", DoubleToString(profitPerdedoraSimulado, 2));
      
      double valorNetoSimulado = plRealizado + profitPerdedoraSimulado;
      Print(">>> VALOR NETO SIMULADO (todo cerrado ahora): ", DoubleToString(valorNetoSimulado, 2));
      
      double ajusteNecesario = g_ganancia_objetivo - valorNetoSimulado;
      Print(">>> Ajuste necesario en la perdedora: ", DoubleToString(ajusteNecesario, 2));
      
      double puntosAdicionales = ajusteNecesario / (volumenTotalAbiertas * valorTickActual);
      Print(">>> Puntos adicionales desde precio actual: ", DoubleToString(puntosAdicionales, 1));
      
      double precioTP;
      if(tipoAbiertas == ORDER_TYPE_BUY)
         precioTP = precioActualCalculo + (puntosAdicionales * punto);
      else
         precioTP = precioActualCalculo - (puntosAdicionales * punto);
      
      precioTP = NormalizeDouble(precioTP, digits);
      
      Print("TP calculado: ", DoubleToString(precioTP, digits));
      Print("Precio actual: ", DoubleToString(precioActualCalculo, digits));
      
      bool tpYaSuperado = false;
      if(tipoAbiertas == ORDER_TYPE_BUY)
         tpYaSuperado = (precioActualCalculo >= precioTP);
      else
         tpYaSuperado = (precioActualCalculo <= precioTP);
      
      if(tpYaSuperado)
      {
         Print(">>> TP YA SUPERADO - Resultado actual ya cumple GananciaM <<<");
         Print(">>> Cerrando perdedora al mercado <<<");
         
         for(int i = PositionsTotal() - 1; i >= 0; i--)
         {
            if(posInfo.SelectByIndex(i))
            {
               if(posInfo.Magic() == g_numero_magico && posInfo.Symbol() == _Symbol)
               {
                  tradeRollOff.PositionClose(posInfo.Ticket());
                  Sleep(50);
               }
            }
         }
         
         for(int i = OrdersTotal() - 1; i >= 0; i--)
         {
            COrderInfo ordI;
            if(ordI.SelectByIndex(i))
            {
               if(ordI.Magic() == g_numero_magico && ordI.Symbol() == _Symbol)
                  tradeRollOff.OrderDelete(ordI.Ticket());
            }
         }
         
         Print(">>> OBJETIVO ALCANZADO");
         return true;
      }
      
      for(int i = 0; i < PositionsTotal(); i++)
      {
         if(posInfo.SelectByIndex(i))
         {
            if(posInfo.Magic() == g_numero_magico && posInfo.Symbol() == _Symbol)
            {
               tradeRollOff.PositionModify(posInfo.Ticket(), 0, precioTP);
            }
         }
      }
      
      // AFINAR TP
      double valorTickRecalc = 0;
      bool tickRecalc = false;
      
      double precioAhora2;
      if(tipoAbiertas == ORDER_TYPE_BUY)
         precioAhora2 = SymbolInfoDouble(_Symbol, SYMBOL_BID);
      else
         precioAhora2 = SymbolInfoDouble(_Symbol, SYMBOL_ASK);
      
      for(int i = 0; i < PositionsTotal(); i++)
      {
         if(posInfo.SelectByIndex(i))
         {
            if(posInfo.Magic() == g_numero_magico && posInfo.Symbol() == _Symbol)
            {
               double vol = posInfo.Volume();
               double pAp = posInfo.PriceOpen();
               double prof = posInfo.Profit();
               ENUM_POSITION_TYPE tPos = posInfo.PositionType();
               
               double dif;
               if(tPos == POSITION_TYPE_BUY) dif = precioAhora2 - pAp;
               else dif = pAp - precioAhora2;
               
               double pts = dif / punto;
               
               if(MathAbs(pts) >= 1.0 && MathAbs(prof) >= 0.01)
               {
                  valorTickRecalc = MathAbs(prof) / MathAbs(pts) / vol;
                  tickRecalc = true;
                  break;
               }
            }
         }
      }
      
      if(!tickRecalc || MathAbs(valorTickRecalc) < 0.1)
         valorTickRecalc = valorTickActual;
      
      double perdidaEsperada = 0;
      for(int i = 0; i < PositionsTotal(); i++)
      {
         if(posInfo.SelectByIndex(i))
         {
            if(posInfo.Magic() == g_numero_magico && posInfo.Symbol() == _Symbol)
            {
               double tp = posInfo.TakeProfit();
               if(tp != 0)
               {
                  double pAp = posInfo.PriceOpen();
                  double vol = posInfo.Volume();
                  ENUM_POSITION_TYPE tPos = posInfo.PositionType();
                  
                  double dTP;
                  if(tPos == POSITION_TYPE_BUY) dTP = tp - pAp;
                  else dTP = pAp - tp;
                  
                  perdidaEsperada += (dTP / punto) * vol * valorTickRecalc;
               }
            }
         }
      }
      
      double resultadoProyectado = plRealizado + perdidaEsperada;
      Print("Resultado proyectado: ", DoubleToString(resultadoProyectado, 3));
      
      bool peligro = (resultadoProyectado <= 0.005);
      
      if(peligro || MathAbs(resultadoProyectado - g_ganancia_objetivo) > 0.015)
      {
         double mejorTP = precioTP;
         double mejorRes = resultadoProyectado;
         
         int rIni = peligro ? 1 : -10;
         int rFin = peligro ? 100 : 10;
         
         for(int ii = rIni; ii <= rFin; ii++)
         {
            double tpP;
            if(tipoAbiertas == ORDER_TYPE_BUY) tpP = precioTP + (ii * punto);
            else tpP = precioTP - (ii * punto);
            tpP = NormalizeDouble(tpP, digits);
            
            double perdP = 0;
            for(int j = 0; j < PositionsTotal(); j++)
            {
               if(posInfo.SelectByIndex(j))
               {
                  if(posInfo.Magic() == g_numero_magico && posInfo.Symbol() == _Symbol)
                  {
                     double pAp = posInfo.PriceOpen();
                     double vol = posInfo.Volume();
                     ENUM_POSITION_TYPE tPos = posInfo.PositionType();
                     double dTP;
                     if(tPos == POSITION_TYPE_BUY) dTP = tpP - pAp;
                     else dTP = pAp - tpP;
                     perdP += (dTP / punto) * vol * valorTickRecalc;
                  }
               }
            }
            
            double resP = plRealizado + perdP;
            
            if(peligro)
            {
               if(resP >= g_ganancia_objetivo)
               {
                  mejorTP = tpP;
                  mejorRes = resP;
                  Print("✅ TP SEGURO: i=", ii, " TP:", DoubleToString(tpP, digits), " Res:", DoubleToString(resP, 3));
                  break;
               }
            }
            else
            {
               if(MathAbs(resP - g_ganancia_objetivo) < MathAbs(mejorRes - g_ganancia_objetivo))
               {
                  mejorTP = tpP;
                  mejorRes = resP;
               }
            }
         }
         
         if(mejorTP != precioTP)
         {
            for(int i = 0; i < PositionsTotal(); i++)
            {
               if(posInfo.SelectByIndex(i))
               {
                  if(posInfo.Magic() == g_numero_magico && posInfo.Symbol() == _Symbol)
                     tradeRollOff.PositionModify(posInfo.Ticket(), 0, mejorTP);
               }
            }
            precioTP = mejorTP;
            Print("TP ajustado a: ", DoubleToString(mejorTP, digits), " Resultado: ", DoubleToString(mejorRes, 3));
         }
      }
   }
   else
   {
      // MODO CIERRA PERDEDORAS
      Print("========================================");
      Print(">>> GANADORAS QUEDAN ABIERTAS <<<");
      Print(">>> Calculando TP desde precio de apertura <<<");
      
      double gananciaRequerida = MathAbs(plRealizado) + g_ganancia_objetivo;
      
      Print("P&L REALIZADO: ", DoubleToString(plRealizado, 2));
      Print("GananciaM: ", DoubleToString(g_ganancia_objetivo, 2));
      Print("Ganancia TOTAL requerida al cierre: ", DoubleToString(gananciaRequerida, 2));
      
      COrderInfo ordInfo;
      for(int i = OrdersTotal() - 1; i >= 0; i--)
      {
         if(ordInfo.SelectByIndex(i))
         {
            if(ordInfo.Magic() == g_numero_magico && ordInfo.Symbol() == _Symbol)
            {
               string com = ordInfo.Comment();
               if(StringFind(com, "RollOff_Proteccion") >= 0)
                  tradeRollOff.OrderDelete(ordInfo.Ticket());
            }
         }
      }
      
      double sumatoriaPV = 0;
      for(int i = 0; i < PositionsTotal(); i++)
      {
         if(posInfo.SelectByIndex(i))
         {
            if(posInfo.Magic() == g_numero_magico && posInfo.Symbol() == _Symbol)
            {
               double pAp = posInfo.PriceOpen();
               double vol = posInfo.Volume();
               sumatoriaPV += pAp * vol;
               
               Print("  Ganadora #", posInfo.Ticket(),
                     " Apertura:", DoubleToString(pAp, digits),
                     " Vol:", DoubleToString(vol, 2));
            }
         }
      }
      
      double precioPromedioGanadoras = sumatoriaPV / volumenTotalAbiertas;
      Print("Precio promedio apertura ganadoras: ", DoubleToString(precioPromedioGanadoras, digits));
      
      double valorTick = 0;
      bool tickOK = false;
      
      double precioCalcG;
      if(tipoAbiertas == ORDER_TYPE_BUY)
         precioCalcG = SymbolInfoDouble(_Symbol, SYMBOL_BID);
      else
         precioCalcG = SymbolInfoDouble(_Symbol, SYMBOL_ASK);
      
      for(int i = 0; i < PositionsTotal(); i++)
      {
         if(posInfo.SelectByIndex(i))
         {
            if(posInfo.Magic() == g_numero_magico && posInfo.Symbol() == _Symbol)
            {
               double vol = posInfo.Volume();
               double pAp = posInfo.PriceOpen();
               double prof = posInfo.Profit();
               ENUM_POSITION_TYPE tPos = posInfo.PositionType();
               
               double dif;
               if(tPos == POSITION_TYPE_BUY) dif = precioCalcG - pAp;
               else dif = pAp - precioCalcG;
               
               double pts = dif / punto;
               
               if(MathAbs(pts) >= 1.0 && MathAbs(prof) >= 0.01)
               {
                  valorTick = MathAbs(prof) / MathAbs(pts) / vol;
                  Print("  Valor TICK extraído: ", DoubleToString(valorTick, 6));
                  tickOK = true;
                  break;
               }
            }
         }
      }
      
      if(!tickOK || MathAbs(valorTick) < 0.1) valorTick = 0.84;
      
      double puntosNecesarios = gananciaRequerida / (volumenTotalAbiertas * valorTick);
      
      double precioTPGanadoras;
      if(tipoAbiertas == ORDER_TYPE_BUY)
         precioTPGanadoras = precioPromedioGanadoras + (puntosNecesarios * punto);
      else
         precioTPGanadoras = precioPromedioGanadoras - (puntosNecesarios * punto);
      
      precioTPGanadoras = NormalizeDouble(precioTPGanadoras, digits);
      
      Print("----------------------------------------------");
      Print(">>> CÁLCULO TP PARA GANADORAS <<<");
      Print("Ganancia requerida: ", DoubleToString(gananciaRequerida, 2));
      Print("Volumen ganadoras: ", DoubleToString(volumenTotalAbiertas, 2));
      Print("Valor TICK: ", DoubleToString(valorTick, 6));
      Print("Puntos necesarios desde apertura: ", DoubleToString(puntosNecesarios, 1));
      Print("Precio apertura promedio: ", DoubleToString(precioPromedioGanadoras, digits));
      Print("TP calculado: ", DoubleToString(precioTPGanadoras, digits));
      Print("Precio actual: ", DoubleToString(precioCalcG, digits));
      
      bool tpYaSuperado = false;
      if(tipoAbiertas == ORDER_TYPE_BUY)
         tpYaSuperado = (precioCalcG >= precioTPGanadoras);
      else
         tpYaSuperado = (precioCalcG <= precioTPGanadoras);
      
      if(tpYaSuperado)
      {
         Print(">>> TP YA SUPERADO - CERRANDO TODO <<<");
         
         for(int i = PositionsTotal() - 1; i >= 0; i--)
         {
            if(posInfo.SelectByIndex(i))
            {
               if(posInfo.Magic() == g_numero_magico && posInfo.Symbol() == _Symbol)
               {
                  tradeRollOff.PositionClose(posInfo.Ticket());
                  Sleep(50);
               }
            }
         }
         
         for(int i = OrdersTotal() - 1; i >= 0; i--)
         {
            COrderInfo ordI;
            if(ordI.SelectByIndex(i))
            {
               if(ordI.Magic() == g_numero_magico && ordI.Symbol() == _Symbol)
                  tradeRollOff.OrderDelete(ordI.Ticket());
            }
         }
         
         Print(">>> OBJETIVO ALCANZADO");
         return true;
      }
      
      int tpsConf = 0;
      for(int i = 0; i < PositionsTotal(); i++)
      {
         if(posInfo.SelectByIndex(i))
         {
            if(posInfo.Magic() == g_numero_magico && posInfo.Symbol() == _Symbol)
            {
               if(tradeRollOff.PositionModify(posInfo.Ticket(), 0, precioTPGanadoras))
               {
                  Print("  ✓ TP ganadora #", posInfo.Ticket(), " → ", DoubleToString(precioTPGanadoras, digits));
                  tpsConf++;
               }
            }
         }
      }
      Print("TPs configurados: ", tpsConf);
      
      // Afinar TP
      double valorTickR = 0;
      bool tickR = false;
      
      double precioAhora3;
      if(tipoAbiertas == ORDER_TYPE_BUY)
         precioAhora3 = SymbolInfoDouble(_Symbol, SYMBOL_BID);
      else
         precioAhora3 = SymbolInfoDouble(_Symbol, SYMBOL_ASK);
      
      for(int i = 0; i < PositionsTotal(); i++)
      {
         if(posInfo.SelectByIndex(i))
         {
            if(posInfo.Magic() == g_numero_magico && posInfo.Symbol() == _Symbol)
            {
               double vol = posInfo.Volume();
               double pAp = posInfo.PriceOpen();
               double prof = posInfo.Profit();
               ENUM_POSITION_TYPE tPos = posInfo.PositionType();
               
               double dif;
               if(tPos == POSITION_TYPE_BUY) dif = precioAhora3 - pAp;
               else dif = pAp - precioAhora3;
               
               double pts = dif / punto;
               
               if(MathAbs(pts) >= 1.0 && MathAbs(prof) >= 0.01)
               {
                  valorTickR = MathAbs(prof) / MathAbs(pts) / vol;
                  tickR = true;
                  break;
               }
            }
         }
      }
      
      if(!tickR || MathAbs(valorTickR) < 0.1) valorTickR = valorTick;
      
      double gananciaEsperada = 0;
      for(int i = 0; i < PositionsTotal(); i++)
      {
         if(posInfo.SelectByIndex(i))
         {
            if(posInfo.Magic() == g_numero_magico && posInfo.Symbol() == _Symbol)
            {
               double tp = posInfo.TakeProfit();
               if(tp != 0)
               {
                  double pAp = posInfo.PriceOpen();
                  double vol = posInfo.Volume();
                  ENUM_POSITION_TYPE tPos = posInfo.PositionType();
                  
                  double dTP;
                  if(tPos == POSITION_TYPE_BUY) dTP = tp - pAp;
                  else dTP = pAp - tp;
                  
                  gananciaEsperada += (dTP / punto) * vol * valorTickR;
               }
            }
         }
      }
      
      double resultadoProyectado = plRealizado + gananciaEsperada;
      Print("Ganancia esperada al TP: ", DoubleToString(gananciaEsperada, 2));
      Print("Resultado proyectado: ", DoubleToString(resultadoProyectado, 3));
      
      bool peligro = (resultadoProyectado <= 0.005);
      
      if(peligro || MathAbs(resultadoProyectado - g_ganancia_objetivo) > 0.015)
      {
         double mejorTP = precioTPGanadoras;
         double mejorRes = resultadoProyectado;
         
         int rIni = peligro ? 1 : -10;
         int rFin = peligro ? 100 : 10;
         
         for(int ii = rIni; ii <= rFin; ii++)
         {
            double tpP;
            if(tipoAbiertas == ORDER_TYPE_BUY)
               tpP = precioTPGanadoras + (ii * punto);
            else
               tpP = precioTPGanadoras - (ii * punto);
            tpP = NormalizeDouble(tpP, digits);
            
            double ganP = 0;
            for(int j = 0; j < PositionsTotal(); j++)
            {
               if(posInfo.SelectByIndex(j))
               {
                  if(posInfo.Magic() == g_numero_magico && posInfo.Symbol() == _Symbol)
                  {
                     double pAp = posInfo.PriceOpen();
                     double vol = posInfo.Volume();
                     ENUM_POSITION_TYPE tPos = posInfo.PositionType();
                     double dTP;
                     if(tPos == POSITION_TYPE_BUY) dTP = tpP - pAp;
                     else dTP = pAp - tpP;
                     ganP += (dTP / punto) * vol * valorTickR;
                  }
               }
            }
            
            double resP = plRealizado + ganP;
            
            if(peligro)
            {
               if(resP >= g_ganancia_objetivo)
               {
                  mejorTP = tpP;
                  mejorRes = resP;
                  Print("✅ TP SEGURO: i=", ii, " TP:", DoubleToString(tpP, digits), " Res:", DoubleToString(resP, 3));
                  break;
               }
            }
            else
            {
               if(MathAbs(resP - g_ganancia_objetivo) < MathAbs(mejorRes - g_ganancia_objetivo))
               {
                  mejorTP = tpP;
                  mejorRes = resP;
               }
            }
         }
         
         if(mejorTP != precioTPGanadoras)
         {
            for(int i = 0; i < PositionsTotal(); i++)
            {
               if(posInfo.SelectByIndex(i))
               {
                  if(posInfo.Magic() == g_numero_magico && posInfo.Symbol() == _Symbol)
                     tradeRollOff.PositionModify(posInfo.Ticket(), 0, mejorTP);
               }
            }
            Print("TP ajustado a: ", DoubleToString(mejorTP, digits), " Resultado: ", DoubleToString(mejorRes, 3));
         }
      }
      else
      {
         Print(">>> Resultado proyectado aceptable: ", DoubleToString(resultadoProyectado, 3), " ✓");
      }
   }
   
   // ORDEN PROTECCIÓN NEUTRALIZADORA
   Print("----------------------------------------------");
   Print(">>> ORDEN PROTECCIÓN NEUTRALIZADORA <<<");
   
   double precioOrdenPendiente;
   ENUM_ORDER_TYPE tipoOrdenPendiente;
   int ticksProteccion = 50;
   
   if(tipoAbiertas == ORDER_TYPE_BUY)
   {
      precioOrdenPendiente = precioActualAntesCierre - (ticksProteccion * punto);
      tipoOrdenPendiente = ORDER_TYPE_SELL_STOP;
   }
   else
   {
      precioOrdenPendiente = precioActualAntesCierre + (ticksProteccion * punto);
      tipoOrdenPendiente = ORDER_TYPE_BUY_STOP;
   }
   
   precioOrdenPendiente = NormalizeDouble(precioOrdenPendiente, digits);
   
   Print("Tipo: ", (tipoOrdenPendiente == ORDER_TYPE_BUY_STOP ? "BUY STOP" : "SELL STOP"));
   Print("Volumen: ", DoubleToString(volumenTotalAbiertas, 2));
   Print("Precio: ", DoubleToString(precioOrdenPendiente, digits));
   
   if(tradeRollOff.OrderOpen(_Symbol, tipoOrdenPendiente, volumenTotalAbiertas, 0,
                      precioOrdenPendiente, 0, 0,
                      ORDER_TIME_GTC, 0,
                      "RollOff_Proteccion"))
   {
      Print("✓ Orden protección #", tradeRollOff.ResultOrder());
   }
   
   // Inicializar trailing
   g_trailing_activado = true;
   g_trailing_precio_referencia = precioActualAntesCierre;
   Print(">>> TRAILING INICIALIZADO <<<");
   Print(">>> Precio referencia: ", DoubleToString(g_trailing_precio_referencia, digits));
   Print(">>> Cada ", g_trailing_salto_ticks, " ticks de avance → mover orden ", g_trailing_salto_ticks, " ticks");
   
   g_precio_activacion_roll_off = precioActualAntesCierre;
   Print("✓ Precio referencia: ", DoubleToString(g_precio_activacion_roll_off, digits));
   
   Print("==========================================");
   Print(">>> Roll-Off #", g_contador_rolloff, " completado");
   Print(">>> Modo: ", (g_modo_rolloff == 0 ? "CIERRA GANADORAS" : "CIERRA PERDEDORAS"));
   Print("==========================================");
   
   g_ultimo_roll_off = TimeCurrent();
   
   return true;
}


//+------------------------------------------------------------------+
//| MonitorearGanadorasRollOff                                       |
//+------------------------------------------------------------------+
void MonitorearGanadorasRollOff()
{
   if(!g_roll_off_activo) return;
   if(!g_sistema_activo) return;
   
   GestionarTrailingOrdenProteccion();
   
   static datetime ultimoRollOffMonitor = 0;
   
   if(g_ultimo_roll_off > ultimoRollOffMonitor)
   {
      ultimoRollOffMonitor = g_ultimo_roll_off;
      Print(">>> MonitorearGanadoras: Esperando siguiente tick después de Roll-Off");
      return;
   }
   
   CPositionInfo posInfo;
   CTrade tradeMonitor;
   tradeMonitor.SetExpertMagicNumber(g_numero_magico);
   
   int posicionesAbiertas = 0;
   for(int i = 0; i < PositionsTotal(); i++)
   {
      if(posInfo.SelectByIndex(i))
      {
         if(posInfo.Magic() == g_numero_magico && posInfo.Symbol() == _Symbol)
         {
            posicionesAbiertas++;
         }
      }
   }
   
   if(posicionesAbiertas == 0)
   {
      Print("========================================");
      Print(">>> TP ALCANZADO - OBJETIVO CUMPLIDO <<<");
      Print("========================================");
      
      COrderInfo ordInfo;
      for(int i = OrdersTotal() - 1; i >= 0; i--)
      {
         if(ordInfo.SelectByIndex(i))
         {
            if(ordInfo.Magic() == g_numero_magico && ordInfo.Symbol() == _Symbol)
            {
               string com = ordInfo.Comment();
               if(StringFind(com, "RollOff_Proteccion") >= 0)
               {
                  tradeMonitor.OrderDelete(ordInfo.Ticket());
               }
            }
         }
      }
      
      g_roll_off_activo = false;
      g_sistema_activo = false;
      g_nivel_actual = 0;
      g_tiempo_primera_entrada = 0;
      g_orden_neutralizadora_activada = false;
      
      Print(">>> Variables reseteadas - Sistema listo");
      return;
   }
   
   // Detección de orden neutralizadora activada
   static int posicionesAnteriores = 0;
   bool ordenNeutralizadoraActivada = (posicionesAbiertas > posicionesAnteriores);
   
   if(ordenNeutralizadoraActivada)
   {
      Print("========================================");
      Print(">>> ORDEN NEUTRALIZADORA ACTIVADA <<<");
      Print("Posiciones anteriores: ", posicionesAnteriores);
      Print("Posiciones actuales: ", posicionesAbiertas);
      Print("========================================");
      
      g_orden_neutralizadora_activada = true;
      
      datetime tiempoMasReciente = 0;
      double precioUltimaEntrada = 0;
      int nivelUltimaEntrada = 0;
      
      for(int i = 0; i < PositionsTotal(); i++)
      {
         if(posInfo.SelectByIndex(i))
         {
            if(posInfo.Magic() == g_numero_magico && posInfo.Symbol() == _Symbol)
            {
               datetime tiempoApertura = posInfo.Time();
               
               if(tiempoApertura > tiempoMasReciente)
               {
                  tiempoMasReciente = tiempoApertura;
                  precioUltimaEntrada = posInfo.PriceOpen();
                  
                  string comentario = posInfo.Comment();
                  if(StringFind(comentario, "Nivel_") >= 0)
                  {
