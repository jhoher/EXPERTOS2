//+------------------------------------------------------------------+
//| Calcular volúmenes totales BUY y SELL                            |
//+------------------------------------------------------------------+
void CalcularVolumenesTotales(double &volumenBuyTotal, double &volumenSellTotal)
{
   volumenBuyTotal = 0;
   volumenSellTotal = 0;
   
   CPositionInfo posInfo;
   
   for(int i = 0; i < PositionsTotal(); i++)
   {
      if(posInfo.SelectByIndex(i))
      {
         if(posInfo.Magic() == g_numero_magico && posInfo.Symbol() == _Symbol)
         {
            double volumen = posInfo.Volume();
            string comentario = posInfo.Comment();
            int nivel = 0;
            
            if(StringFind(comentario, "Nivel_") >= 0)
            {
               nivel = (int)StringToInteger(StringSubstr(comentario, 6));
            }
            
            ENUM_ORDER_TYPE tipoReal;
            if(nivel % 2 == 1)
               tipoReal = g_tipo_inicial;
            else
               tipoReal = (g_tipo_inicial == ORDER_TYPE_BUY) ? ORDER_TYPE_SELL : ORDER_TYPE_BUY;
            
            if(tipoReal == ORDER_TYPE_BUY)
               volumenBuyTotal += volumen;
            else
               volumenSellTotal += volumen;
         }
      }
   }
}

//+------------------------------------------------------------------+
//| Verificar si hay neutralización de volúmenes                     |
//+------------------------------------------------------------------+
bool VerificarNeutralizacion()
{
   double volBuy = 0, volSell = 0;
   CalcularVolumenesTotales(volBuy, volSell);
   
   if(volBuy == 0 || volSell == 0)
      return false;
   
   double diferencia = MathAbs(volBuy - volSell);
   double minVol = SymbolInfoDouble(_Symbol, SYMBOL_VOLUME_MIN);
   
   return (diferencia < minVol * 2);
}

//+------------------------------------------------------------------+
//| Calcular P&L actual de todas las posiciones                      |
//+------------------------------------------------------------------+
double CalcularPLTotal()
{
   double plTotal = 0;
   CPositionInfo posInfo;
   
   for(int i = 0; i < PositionsTotal(); i++)
   {
      if(posInfo.SelectByIndex(i))
      {
         if(posInfo.Magic() == g_numero_magico && posInfo.Symbol() == _Symbol)
         {
            plTotal += posInfo.Profit() + posInfo.Swap() + posInfo.Commission();
         }
      }
   }
   
   return plTotal;
}

//+------------------------------------------------------------------+
//| Calcular P&L separado por tipo (BUY/SELL)                        |
//+------------------------------------------------------------------+
void CalcularPLPorTipo(double &plBuy, double &plSell)
{
   plBuy = 0;
   plSell = 0;
   
   CPositionInfo posInfo;
   
   for(int i = 0; i < PositionsTotal(); i++)
   {
      if(posInfo.SelectByIndex(i))
      {
         if(posInfo.Magic() == g_numero_magico && posInfo.Symbol() == _Symbol)
         {
            double pl = posInfo.Profit() + posInfo.Swap() + posInfo.Commission();
            
            if(posInfo.PositionType() == POSITION_TYPE_BUY)
               plBuy += pl;
            else
               plSell += pl;
         }
      }
   }
}


// ================================================================
// EjecutarRollOff - VERSIÓN ESTRUCTURA M3 (v4.3)
// La dirección del cierre la decide g_ultima_senal_estructura:
//   SENAL_ALCISTA → cerrar SELL, dejar BUY (calcular TP arriba)
//   SENAL_BAJISTA → cerrar BUY,  dejar SELL (calcular TP abajo)
// Ya NO se usa ADX, ni alternancia, ni regla de contradicción,
// ni el concepto de "ganadoras vs perdedoras".
// ================================================================
bool EjecutarRollOff()
{
   // ============ Validar señal estructural ============
   if(g_ultima_senal_estructura != SENAL_ALCISTA &&
      g_ultima_senal_estructura != SENAL_BAJISTA)
   {
      Print(">>> ERROR: EjecutarRollOff llamado sin señal estructural válida");
      Print(">>> g_ultima_senal_estructura = ", g_ultima_senal_estructura);
      return false;
   }
   
   bool esAlcista = (g_ultima_senal_estructura == SENAL_ALCISTA);
   
   // Tipo que queda abierto (el del lado de la tendencia M3)
   ENUM_POSITION_TYPE tipoMT5_aCerrar = esAlcista ? POSITION_TYPE_SELL : POSITION_TYPE_BUY;
   ENUM_ORDER_TYPE    tipoAbiertas    = esAlcista ? ORDER_TYPE_BUY     : ORDER_TYPE_SELL;
   
   g_contador_rolloff++;
   
   Print("========================================");
   Print("========== EJECUTANDO ROLL-OFF #", g_contador_rolloff, " ==========");
   Print(">>> SEÑAL M3: ", (esAlcista ? "ALCISTA" : "BAJISTA"));
   Print(">>> CIERRA: ", (esAlcista ? "SELL" : "BUY"));
   Print(">>> QUEDAN ABIERTAS: ", (esAlcista ? "BUY" : "SELL"));
   Print("========================================");
   
   CTrade tradeRollOff;
   CPositionInfo posInfo;
   tradeRollOff.SetExpertMagicNumber(g_numero_magico);
   
   double punto = SymbolInfoDouble(_Symbol, SYMBOL_POINT);
   int digits = (int)SymbolInfoInteger(_Symbol, SYMBOL_DIGITS);
   
   // Precio de referencia para la orden de protección neutralizadora
   // Es el precio actual del lado que queda abierto
   double precioActualAntesCierre;
   if(tipoAbiertas == ORDER_TYPE_BUY)
      precioActualAntesCierre = SymbolInfoDouble(_Symbol, SYMBOL_BID);
   else
      precioActualAntesCierre = SymbolInfoDouble(_Symbol, SYMBOL_ASK);
   
   Print("Precio actual (referencia): ", DoubleToString(precioActualAntesCierre, digits));
   
   // PASO 0: Leer swap de todas
   Print(">>> PASO 0: LEER SWAP DE TODAS LAS POSICIONES <<<");
   double swapTotalTodasAbiertas = 0;
   
   for(int i = 0; i < PositionsTotal(); i++)
   {
      if(posInfo.SelectByIndex(i))
      {
         if(posInfo.Magic() == g_numero_magico && posInfo.Symbol() == _Symbol)
         {
            ulong ticket = posInfo.Ticket();
            double swapPos = posInfo.Swap();
            ENUM_POSITION_TYPE tipoPosicion = posInfo.PositionType();
            string comentario = posInfo.Comment();
            
            Print("  Pos #", ticket,
                  " Tipo:", (tipoPosicion == POSITION_TYPE_BUY ? "BUY" : "SELL"),
                  " Com:", comentario,
                  " Swap: ", DoubleToString(swapPos, 2));
            
            swapTotalTodasAbiertas += swapPos;
         }
      }
   }
   
   Print("SWAP TOTAL TODAS ABIERTAS: ", DoubleToString(swapTotalTodasAbiertas, 2));
   
   // PASO 1: Cerrar SEGÚN ESTRUCTURA M3 (no según ganadoras/perdedoras)
   Print("========================================");
   Print(">>> PASO 1: CERRANDO ", (esAlcista ? "SELL" : "BUY"), " (contra-tendencia M3) <<<");
   
   ulong ticketsCerrar[];
   int contadorTickets = 0;
   double volumenTotalCerradas = 0;
   
   for(int i = PositionsTotal() - 1; i >= 0; i--)
   {
      if(posInfo.SelectByIndex(i))
      {
         if(posInfo.Magic() == g_numero_magico && posInfo.Symbol() == _Symbol)
         {
            ENUM_POSITION_TYPE tipoPosicion = posInfo.PositionType();
            ulong ticket = posInfo.Ticket();
            double volumen = posInfo.Volume();
            string comentario = posInfo.Comment();
            
            if(tipoPosicion == tipoMT5_aCerrar)
            {
               Print("  #", ticket,
                     " Vol:", DoubleToString(volumen, 2),
                     " Tipo:", (tipoPosicion == POSITION_TYPE_BUY ? "BUY" : "SELL"),
                     " Com:", comentario, " → SE CERRARÁ");
               
               ArrayResize(ticketsCerrar, contadorTickets + 1);
               ticketsCerrar[contadorTickets] = ticket;
               contadorTickets++;
               volumenTotalCerradas += volumen;
            }
            else
            {
               Print("  #", ticket,
                     " Vol:", DoubleToString(volumen, 2),
                     " Tipo:", (tipoPosicion == POSITION_TYPE_BUY ? "BUY" : "SELL"),
                     " Com:", comentario, " → QUEDA ABIERTA");
            }
         }
      }
   }
   
   Print("----------------------------------------------");
   Print("Posiciones a cerrar: ", contadorTickets);
   Print("Volumen cerrado: ", DoubleToString(volumenTotalCerradas, 2));
   
   for(int i = 0; i < contadorTickets; i++)
   {
      ulong ticket = ticketsCerrar[i];
      if(tradeRollOff.PositionClose(ticket))
      {
         Print("  ✓ Cerrada #", ticket);
         Sleep(100);
      }
   }
   
   Sleep(200);
   
   // Leer profit de cerradas
   Print("--- Leyendo TODA la secuencia desde inicio ---");
   double profitTodasCerradas = 0;
   double swapTodasCerradas = 0;
   int cantidadCerradas = 0;
   
   datetime desde = g_tiempo_primera_entrada;
   datetime hasta = TimeCurrent();
   
   if(HistorySelect(desde, hasta))
   {
      int totalDeals = HistoryDealsTotal();
      
      for(int i = totalDeals - 1; i >= 0; i--)
      {
         ulong dealTicket = HistoryDealGetTicket(i);
         
         if(dealTicket > 0)
         {
            long magic = HistoryDealGetInteger(dealTicket, DEAL_MAGIC);
            string symbol = HistoryDealGetString(dealTicket, DEAL_SYMBOL);
            long dealEntry = HistoryDealGetInteger(dealTicket, DEAL_ENTRY);
            
            if(magic == g_numero_magico && symbol == _Symbol && dealEntry == DEAL_ENTRY_OUT)
            {
               double profitReal = HistoryDealGetDouble(dealTicket, DEAL_PROFIT);
               double swapReal = HistoryDealGetDouble(dealTicket, DEAL_SWAP);
               double volumen = HistoryDealGetDouble(dealTicket, DEAL_VOLUME);
               ulong positionTicket = HistoryDealGetInteger(dealTicket, DEAL_POSITION_ID);
               
               Print("  Deal #", dealTicket, " Pos #", positionTicket);
               Print("    Profit: ", DoubleToString(profitReal, 2));
               Print("    Swap: ", DoubleToString(swapReal, 2));
               Print("    Volumen: ", DoubleToString(volumen, 2));
               
               profitTodasCerradas += profitReal;
               swapTodasCerradas += swapReal;
               cantidadCerradas++;
            }
         }
      }
   }
   
   Print("----------------------------------------------");
   Print("Total cerradas: ", cantidadCerradas);
   Print("PROFIT CERRADAS: ", DoubleToString(profitTodasCerradas, 2));
   
   // Posiciones abiertas restantes
   Print("--- Posiciones que quedan abiertas ---");
   double swapAbiertas = 0;
   int cantidadAbiertas = 0;
   double volumenTotalAbiertas = 0;
   
   for(int i = 0; i < PositionsTotal(); i++)
   {
      if(posInfo.SelectByIndex(i))
      {
         if(posInfo.Magic() == g_numero_magico && posInfo.Symbol() == _Symbol)
         {
            double swapPos = posInfo.Swap();
            ulong ticket = posInfo.Ticket();
            double volumen = posInfo.Volume();
            
            Print("  Abierta #", ticket, ": Swap=", DoubleToString(swapPos, 2));
            
            swapAbiertas += swapPos;
            volumenTotalAbiertas += volumen;
            cantidadAbiertas++;
         }
      }
   }
   
   Print("Total abiertas: ", cantidadAbiertas);
   Print("Volumen total abiertas: ", DoubleToString(volumenTotalAbiertas, 2));
   Print("SWAP ABIERTAS: ", DoubleToString(swapAbiertas, 2));
   
   if(cantidadAbiertas == 0)
   {
      Print("✗ ERROR: No hay posiciones abiertas después del cierre");
      return false;
   }
   
   // Swap total real
   double swapDealsAnteriores = 0;
   
   if(HistorySelect(desde, hasta))
   {
      int totalDeals = HistoryDealsTotal();
      for(int i = totalDeals - 1; i >= 0; i--)
      {
         ulong dealTicket = HistoryDealGetTicket(i);
         if(dealTicket > 0)
         {
            long magic = HistoryDealGetInteger(dealTicket, DEAL_MAGIC);
            string symbol = HistoryDealGetString(dealTicket, DEAL_SYMBOL);
            long dealEntry = HistoryDealGetInteger(dealTicket, DEAL_ENTRY);
            datetime dealTime = (datetime)HistoryDealGetInteger(dealTicket, DEAL_TIME);
            
            if(magic == g_numero_magico && symbol == _Symbol && dealEntry == DEAL_ENTRY_OUT)
            {
               if(dealTime < TimeCurrent() - 5)
               {
                  double swapDeal = HistoryDealGetDouble(dealTicket, DEAL_SWAP);
                  swapDealsAnteriores += swapDeal;
               }
            }
         }
      }
   }
   
   double swapTotalReal = swapTotalTodasAbiertas + swapDealsAnteriores;
   Print("SWAP TOTAL REAL: ", DoubleToString(swapTotalReal, 2));
   
   // PASO 2: Comisiones totales
   Print(">>> PASO 2: COMISIONES TOTALES <<<");
   double comisionesTotales = 0;
   
   if(HistorySelect(desde, hasta))
   {
      int totalDeals = HistoryDealsTotal();
      for(int i = totalDeals - 1; i >= 0; i--)
      {
         ulong dealTicket = HistoryDealGetTicket(i);
         if(dealTicket > 0)
         {
            long magic = HistoryDealGetInteger(dealTicket, DEAL_MAGIC);
            string symbol = HistoryDealGetString(dealTicket, DEAL_SYMBOL);
            long dealEntry = HistoryDealGetInteger(dealTicket, DEAL_ENTRY);
            
            if(magic == g_numero_magico && symbol == _Symbol && dealEntry == DEAL_ENTRY_OUT)
            {
               double volumen = HistoryDealGetDouble(dealTicket, DEAL_VOLUME);
               double comision = CalcularComisionPepperstone(volumen, _Symbol);
               comisionesTotales += comision;
            }
         }
      }
   }
   
   for(int i = 0; i < PositionsTotal(); i++)
   {
      if(posInfo.SelectByIndex(i))
      {
         if(posInfo.Magic() == g_numero_magico && posInfo.Symbol() == _Symbol)
         {
            double volumen = posInfo.Volume();
            double comision = CalcularComisionPepperstone(volumen, _Symbol);
            comisionesTotales += comision;
         }
      }
   }
   
   Print("COMISIONES TOTALES: ", DoubleToString(comisionesTotales, 2));
   
   // PASO 3: P&L realizado
   Print(">>> PASO 3: P&L REALIZADO <<<");
   double plRealizado = profitTodasCerradas + swapTotalReal - comisionesTotales;
   
   Print("PROFIT CERRADAS: ", DoubleToString(profitTodasCerradas, 2));
   Print("SWAP TOTAL REAL: ", DoubleToString(swapTotalReal, 2), " (incluye abiertas y cerradas)");
   Print("COMISIONES: -", DoubleToString(comisionesTotales, 2));
   Print("P&L REALIZADO: ", DoubleToString(plRealizado, 2));
   
   // ============ CALCULAR TP PARA POSICIONES QUE QUEDAN ABIERTAS ============
   // Estas son del lado de la tendencia M3 (BUY si alcista, SELL si bajista).
   // El TP se calcula desde el precio PROMEDIO de apertura de las abiertas
   // para alcanzar la ganancia total requerida.
   //
   // Ganancia requerida de las abiertas = GananciaM - plRealizado
   //   - Si plRealizado < 0 → las abiertas deben ganar |plRealizado| + GananciaM
   //   - Si plRealizado > 0 → las abiertas deben ganar (GananciaM - plRealizado)
   //                           (si esto es negativo/cero, TP ya cumplido)
   // ====================================================================
   Print("========================================");
   Print(">>> CALCULANDO TP PARA ", (tipoAbiertas == ORDER_TYPE_BUY ? "BUY" : "SELL"), " QUE QUEDAN ABIERTAS <<<");
   
   // Cancelar órdenes de protección pendientes previas (si existen)
   COrderInfo ordInfo;
   for(int i = OrdersTotal() - 1; i >= 0; i--)
   {
      if(ordInfo.SelectByIndex(i))
      {
         if(ordInfo.Magic() == g_numero_magico && ordInfo.Symbol() == _Symbol)
         {
            string com = ordInfo.Comment();
            if(StringFind(com, "RollOff_Proteccion") >= 0)
               tradeRollOff.OrderDelete(ordInfo.Ticket());
         }
      }
   }
   
   // Precio promedio ponderado por volumen de las posiciones abiertas
   double sumatoriaPV = 0;
   for(int i = 0; i < PositionsTotal(); i++)
   {
      if(posInfo.SelectByIndex(i))
      {
         if(posInfo.Magic() == g_numero_magico && posInfo.Symbol() == _Symbol)
         {
            double pAp = posInfo.PriceOpen();
            double vol = posInfo.Volume();
            sumatoriaPV += pAp * vol;
            
            Print("  Abierta #", posInfo.Ticket(),
                  " Apertura:", DoubleToString(pAp, digits),
                  " Vol:", DoubleToString(vol, 2));
         }
      }
   }
   
   double precioPromedioAbiertas = sumatoriaPV / volumenTotalAbiertas;
   Print("Precio promedio apertura: ", DoubleToString(precioPromedioAbiertas, digits));
   
   // Extraer valor del tick por lote usando profit actual de alguna posición
   double precioCalc;
   if(tipoAbiertas == ORDER_TYPE_BUY)
      precioCalc = SymbolInfoDouble(_Symbol, SYMBOL_BID);
   else
      precioCalc = SymbolInfoDouble(_Symbol, SYMBOL_ASK);
   
   double valorTick = 0;
   bool tickOK = false;
   
   for(int i = 0; i < PositionsTotal(); i++)
   {
      if(posInfo.SelectByIndex(i))
      {
         if(posInfo.Magic() == g_numero_magico && posInfo.Symbol() == _Symbol)
         {
            double vol = posInfo.Volume();
            double pAp = posInfo.PriceOpen();
            double prof = posInfo.Profit();
            ENUM_POSITION_TYPE tPos = posInfo.PositionType();
            
            double dif;
            if(tPos == POSITION_TYPE_BUY) dif = precioCalc - pAp;
            else dif = pAp - precioCalc;
            
            double pts = dif / punto;
            
            if(MathAbs(pts) >= 1.0 && MathAbs(prof) >= 0.01)
            {
               valorTick = MathAbs(prof) / MathAbs(pts) / vol;
               Print("  Valor TICK extraído: ", DoubleToString(valorTick, 6));
               tickOK = true;
               break;
            }
         }
      }
   }
   
   if(!tickOK || MathAbs(valorTick) < 0.1) valorTick = 0.84;
   
   // Ganancia requerida de las posiciones abiertas
   double gananciaRequeridaDeAbiertas = g_ganancia_objetivo - plRealizado;
   
   Print("----------------------------------------------");
   Print("P&L REALIZADO: ", DoubleToString(plRealizado, 2));
   Print("GananciaM: ", DoubleToString(g_ganancia_objetivo, 2));
   Print("Ganancia requerida de las abiertas: ", DoubleToString(gananciaRequeridaDeAbiertas, 2));
   
   double puntosNecesarios = gananciaRequeridaDeAbiertas / (volumenTotalAbiertas * valorTick);
   
   double precioTP;
   if(tipoAbiertas == ORDER_TYPE_BUY)
      precioTP = precioPromedioAbiertas + (puntosNecesarios * punto);
   else
      precioTP = precioPromedioAbiertas - (puntosNecesarios * punto);
   
   precioTP = NormalizeDouble(precioTP, digits);
   
   Print("Volumen abiertas: ", DoubleToString(volumenTotalAbiertas, 2));
   Print("Valor TICK: ", DoubleToString(valorTick, 6));
   Print("Puntos necesarios desde apertura: ", DoubleToString(puntosNecesarios, 1));
   Print("Precio apertura promedio: ", DoubleToString(precioPromedioAbiertas, digits));
   Print("TP calculado: ", DoubleToString(precioTP, digits));
   Print("Precio actual: ", DoubleToString(precioCalc, digits));
   
   // Si el TP ya está alcanzado al precio actual, cerrar todo
   bool tpYaSuperado = false;
   if(tipoAbiertas == ORDER_TYPE_BUY)
      tpYaSuperado = (precioCalc >= precioTP);
   else
      tpYaSuperado = (precioCalc <= precioTP);
   
   if(tpYaSuperado)
   {
      Print(">>> TP YA SUPERADO - Resultado actual ya cumple GananciaM <<<");
      Print(">>> Cerrando posiciones abiertas al mercado <<<");
      
      for(int i = PositionsTotal() - 1; i >= 0; i--)
      {
         if(posInfo.SelectByIndex(i))
         {
            if(posInfo.Magic() == g_numero_magico && posInfo.Symbol() == _Symbol)
            {
               tradeRollOff.PositionClose(posInfo.Ticket());
               Sleep(50);
            }
         }
      }
      
      for(int i = OrdersTotal() - 1; i >= 0; i--)
      {
         COrderInfo ordI;
         if(ordI.SelectByIndex(i))
         {
            if(ordI.Magic() == g_numero_magico && ordI.Symbol() == _Symbol)
               tradeRollOff.OrderDelete(ordI.Ticket());
         }
      }
      
      Print(">>> OBJETIVO ALCANZADO");
      return true;
   }
   
   // Configurar el TP en cada posición abierta
   int tpsConf = 0;
   for(int i = 0; i < PositionsTotal(); i++)
   {
      if(posInfo.SelectByIndex(i))
      {
         if(posInfo.Magic() == g_numero_magico && posInfo.Symbol() == _Symbol)
         {
            if(tradeRollOff.PositionModify(posInfo.Ticket(), 0, precioTP))
            {
               Print("  ✓ TP #", posInfo.Ticket(), " → ", DoubleToString(precioTP, digits));
               tpsConf++;
            }
         }
      }
   }
   Print("TPs configurados: ", tpsConf);
   
   // ============ AFINAR TP ============
   double valorTickR = 0;
   bool tickR = false;
   
   double precioAhora2;
   if(tipoAbiertas == ORDER_TYPE_BUY)
      precioAhora2 = SymbolInfoDouble(_Symbol, SYMBOL_BID);
   else
      precioAhora2 = SymbolInfoDouble(_Symbol, SYMBOL_ASK);
   
   for(int i = 0; i < PositionsTotal(); i++)
   {
      if(posInfo.SelectByIndex(i))
      {
         if(posInfo.Magic() == g_numero_magico && posInfo.Symbol() == _Symbol)
         {
            double vol = posInfo.Volume();
            double pAp = posInfo.PriceOpen();
            double prof = posInfo.Profit();
            ENUM_POSITION_TYPE tPos = posInfo.PositionType();
            
            double dif;
            if(tPos == POSITION_TYPE_BUY) dif = precioAhora2 - pAp;
            else dif = pAp - precioAhora2;
            
            double pts = dif / punto;
            
            if(MathAbs(pts) >= 1.0 && MathAbs(prof) >= 0.01)
            {
               valorTickR = MathAbs(prof) / MathAbs(pts) / vol;
               tickR = true;
               break;
            }
         }
      }
   }
   
   if(!tickR || MathAbs(valorTickR) < 0.1) valorTickR = valorTick;
   
   double gananciaEsperada = 0;
   for(int i = 0; i < PositionsTotal(); i++)
   {
      if(posInfo.SelectByIndex(i))
      {
         if(posInfo.Magic() == g_numero_magico && posInfo.Symbol() == _Symbol)
         {
            double tp = posInfo.TakeProfit();
            if(tp != 0)
            {
               double pAp = posInfo.PriceOpen();
               double vol = posInfo.Volume();
               ENUM_POSITION_TYPE tPos = posInfo.PositionType();
               
               double dTP;
               if(tPos == POSITION_TYPE_BUY) dTP = tp - pAp;
               else dTP = pAp - tp;
               
               gananciaEsperada += (dTP / punto) * vol * valorTickR;
            }
         }
      }
   }
   
   double resultadoProyectado = plRealizado + gananciaEsperada;
   Print("Ganancia esperada al TP: ", DoubleToString(gananciaEsperada, 2));
   Print("Resultado proyectado: ", DoubleToString(resultadoProyectado, 3));
   
   bool peligro = (resultadoProyectado <= 0.005);
   
   if(peligro || MathAbs(resultadoProyectado - g_ganancia_objetivo) > 0.015)
   {
      double mejorTP = precioTP;
      double mejorRes = resultadoProyectado;
      
      int rIni = peligro ? 1 : -10;
      int rFin = peligro ? 100 : 10;
      
      for(int ii = rIni; ii <= rFin; ii++)
      {
         double tpP;
         if(tipoAbiertas == ORDER_TYPE_BUY)
            tpP = precioTP + (ii * punto);
         else
            tpP = precioTP - (ii * punto);
         tpP = NormalizeDouble(tpP, digits);
         
         double ganP = 0;
         for(int j = 0; j < PositionsTotal(); j++)
         {
            if(posInfo.SelectByIndex(j))
            {
               if(posInfo.Magic() == g_numero_magico && posInfo.Symbol() == _Symbol)
               {
                  double pAp = posInfo.PriceOpen();
                  double vol = posInfo.Volume();
                  ENUM_POSITION_TYPE tPos = posInfo.PositionType();
                  double dTP;
                  if(tPos == POSITION_TYPE_BUY) dTP = tpP - pAp;
                  else dTP = pAp - tpP;
                  ganP += (dTP / punto) * vol * valorTickR;
               }
            }
         }
         
         double resP = plRealizado + ganP;
         
         if(peligro)
         {
            if(resP >= g_ganancia_objetivo)
            {
               mejorTP = tpP;
               mejorRes = resP;
               Print("✅ TP SEGURO: i=", ii, " TP:", DoubleToString(tpP, digits), " Res:", DoubleToString(resP, 3));
               break;
            }
         }
         else
         {
            if(MathAbs(resP - g_ganancia_objetivo) < MathAbs(mejorRes - g_ganancia_objetivo))
            {
               mejorTP = tpP;
               mejorRes = resP;
            }
         }
      }
      
      if(mejorTP != precioTP)
      {
         for(int i = 0; i < PositionsTotal(); i++)
         {
            if(posInfo.SelectByIndex(i))
            {
               if(posInfo.Magic() == g_numero_magico && posInfo.Symbol() == _Symbol)
                  tradeRollOff.PositionModify(posInfo.Ticket(), 0, mejorTP);
            }
         }
         precioTP = mejorTP;
         Print("TP ajustado a: ", DoubleToString(mejorTP, digits), " Resultado: ", DoubleToString(mejorRes, 3));
      }
   }
   else
   {
      Print(">>> Resultado proyectado aceptable: ", DoubleToString(resultadoProyectado, 3), " ✓");
   }
   
   // ORDEN PROTECCIÓN NEUTRALIZADORA
   Print("----------------------------------------------");
   Print(">>> ORDEN PROTECCIÓN NEUTRALIZADORA <<<");
   
   double precioOrdenPendiente;
   ENUM_ORDER_TYPE tipoOrdenPendiente;
   int ticksProteccion = 50;
   
   if(tipoAbiertas == ORDER_TYPE_BUY)
   {
      precioOrdenPendiente = precioActualAntesCierre - (ticksProteccion * punto);
      tipoOrdenPendiente = ORDER_TYPE_SELL_STOP;
   }
   else
   {
      precioOrdenPendiente = precioActualAntesCierre + (ticksProteccion * punto);
      tipoOrdenPendiente = ORDER_TYPE_BUY_STOP;
   }
   
   precioOrdenPendiente = NormalizeDouble(precioOrdenPendiente, digits);
   
   Print("Tipo: ", (tipoOrdenPendiente == ORDER_TYPE_BUY_STOP ? "BUY STOP" : "SELL STOP"));
   Print("Volumen: ", DoubleToString(volumenTotalAbiertas, 2));
   Print("Precio: ", DoubleToString(precioOrdenPendiente, digits));
   
   if(tradeRollOff.OrderOpen(_Symbol, tipoOrdenPendiente, volumenTotalAbiertas, 0,
                      precioOrdenPendiente, 0, 0,
                      ORDER_TIME_GTC, 0,
                      "RollOff_Proteccion"))
   {
      Print("✓ Orden protección #", tradeRollOff.ResultOrder());
   }
   
   // Inicializar trailing
   g_trailing_activado = true;
   g_trailing_precio_referencia = precioActualAntesCierre;
   Print(">>> TRAILING INICIALIZADO <<<");
   Print(">>> Precio referencia: ", DoubleToString(g_trailing_precio_referencia, digits));
   Print(">>> Cada ", g_trailing_salto_ticks, " ticks de avance → mover orden ", g_trailing_salto_ticks, " ticks");
   
   g_precio_activacion_roll_off = precioActualAntesCierre;
   Print("✓ Precio referencia: ", DoubleToString(g_precio_activacion_roll_off, digits));
   
   Print("==========================================");
   Print(">>> Roll-Off #", g_contador_rolloff, " completado");
   Print(">>> Dirección M3: ", (esAlcista ? "ALCISTA (BUY abiertas)" : "BAJISTA (SELL abiertas)"));
   Print("==========================================");
   
   g_ultimo_roll_off = TimeCurrent();
   
   return true;
}


//+------------------------------------------------------------------+
//| MonitorearGanadorasRollOff                                       |
//+------------------------------------------------------------------+
void MonitorearGanadorasRollOff()
{
   if(!g_roll_off_activo) return;
   if(!g_sistema_activo) return;
   
   GestionarTrailingOrdenProteccion();
   
   static datetime ultimoRollOffMonitor = 0;
   
   if(g_ultimo_roll_off > ultimoRollOffMonitor)
   {
      ultimoRollOffMonitor = g_ultimo_roll_off;
      Print(">>> MonitorearGanadoras: Esperando siguiente tick después de Roll-Off");
      return;
   }
   
   CPositionInfo posInfo;
   CTrade tradeMonitor;
   tradeMonitor.SetExpertMagicNumber(g_numero_magico);
   
   int posicionesAbiertas = 0;
   for(int i = 0; i < PositionsTotal(); i++)
   {
      if(posInfo.SelectByIndex(i))
      {
         if(posInfo.Magic() == g_numero_magico && posInfo.Symbol() == _Symbol)
         {
            posicionesAbiertas++;
         }
      }
   }
   
   if(posicionesAbiertas == 0)
   {
      Print("========================================");
      Print(">>> TP ALCANZADO - OBJETIVO CUMPLIDO <<<");
      Print("========================================");
      
      COrderInfo ordInfo;
      for(int i = OrdersTotal() - 1; i >= 0; i--)
      {
         if(ordInfo.SelectByIndex(i))
         {
            if(ordInfo.Magic() == g_numero_magico && ordInfo.Symbol() == _Symbol)
            {
               string com = ordInfo.Comment();
               if(StringFind(com, "RollOff_Proteccion") >= 0)
               {
                  tradeMonitor.OrderDelete(ordInfo.Ticket());
               }
            }
         }
      }
      
      g_roll_off_activo = false;
      g_sistema_activo = false;
      g_nivel_actual = 0;
      g_tiempo_primera_entrada = 0;
      g_orden_neutralizadora_activada = false;
      
      Print(">>> Variables reseteadas - Sistema listo");
      return;
   }
   
   // Detección de orden neutralizadora activada
   static int posicionesAnteriores = 0;
   bool ordenNeutralizadoraActivada = (posicionesAbiertas > posicionesAnteriores);
   
   if(ordenNeutralizadoraActivada)
   {
      Print("========================================");
      Print(">>> ORDEN NEUTRALIZADORA ACTIVADA <<<");
      Print("Posiciones anteriores: ", posicionesAnteriores);
      Print("Posiciones actuales: ", posicionesAbiertas);
      Print("========================================");
      
      g_orden_neutralizadora_activada = true;
      
      datetime tiempoMasReciente = 0;
      double precioUltimaEntrada = 0;
      int nivelUltimaEntrada = 0;
      
      for(int i = 0; i < PositionsTotal(); i++)
      {
         if(posInfo.SelectByIndex(i))
         {
            if(posInfo.Magic() == g_numero_magico && posInfo.Symbol() == _Symbol)
            {
               datetime tiempoApertura = posInfo.Time();
               
               if(tiempoApertura > tiempoMasReciente)
               {
                  tiempoMasReciente = tiempoApertura;
                  precioUltimaEntrada = posInfo.PriceOpen();
                  
                  string comentario = posInfo.Comment();
                  if(StringFind(comentario, "Nivel_") >= 0)
                  {
                     nivelUltimaEntrada = (int)StringToInteger(StringSubstr(comentario, 6));
                  }
               }
            }
         }
      }
      
      if(precioUltimaEntrada > 0)
      {
         g_precio_activacion_roll_off = precioUltimaEntrada;
         
         Print(">>> PRECIO REFERENCIA ACTUALIZADO <<<");
         Print(">>> Última entrada (Nivel ", nivelUltimaEntrada, "): ",
               DoubleToString(precioUltimaEntrada, _Digits));
         Print(">>> g_precio_activacion_roll_off = ",
               DoubleToString(g_precio_activacion_roll_off, _Digits));
      }
      
      Print(">>> NEUTRALIZACIÓN ACTIVADA POR ORDEN <<<");
      
      // =========================================================
      // v4.3: Siempre quitamos TODOS los TP/SL cuando se reactiva
      // la neutralización. Ya no hay modo "ganadoras vs perdedoras":
      // ahora hay dos lados nuevamente y hay que esperar la próxima
      // señal de estructura M3 para decidir cuál cerrar.
      // =========================================================
      Print(">>> QUITANDO TODOS LOS TP/SL (nueva neutralización detectada) <<<");
      
      int tpSlQuitados = 0;
      for(int i = 0; i < PositionsTotal(); i++)
      {
         if(posInfo.SelectByIndex(i))
         {
            if(posInfo.Magic() == g_numero_magico && posInfo.Symbol() == _Symbol)
            {
               ulong ticket = posInfo.Ticket();
               double tp = posInfo.TakeProfit();
               double sl = posInfo.StopLoss();
               if(tp != 0 || sl != 0)
               {
                  if(tradeMonitor.PositionModify(ticket, 0, 0))
                  {
                     Print("  ✓ TP/SL quitados #", ticket);
                     tpSlQuitados++;
                     Sleep(50);
                  }
               }
            }
         }
      }
      Print(">>> TPs quitados: ", tpSlQuitados);
      
      // Cancelar órdenes de protección pendientes
      COrderInfo ordInfo;
      int ordenesCanceladas = 0;
      for(int i = OrdersTotal() - 1; i >= 0; i--)
      {
         if(ordInfo.SelectByIndex(i))
         {
            if(ordInfo.Magic() == g_numero_magico && ordInfo.Symbol() == _Symbol)
            {
               string com = ordInfo.Comment();
               if(StringFind(com, "RollOff_Proteccion") >= 0)
               {
                  if(tradeMonitor.OrderDelete(ordInfo.Ticket()))
                  {
                     Print("  ✓ Orden cancelada #", ordInfo.Ticket());
                     ordenesCanceladas++;
                  }
               }
            }
         }
      }
      
      Print(">>> Órdenes canceladas: ", ordenesCanceladas);
      Print("========================================");
   }
   
   posicionesAnteriores = posicionesAbiertas;
   
   static datetime ultimoReporte = 0;
   if(TimeCurrent() - ultimoReporte > 10)
   {
      int digits = (int)SymbolInfoInteger(_Symbol, SYMBOL_DIGITS);
      
      Print("--- Roll-Off activo ---");
      Print("Posiciones: ", posicionesAbiertas);
      
      bool estadoNeutralizado = g_orden_neutralizadora_activada || VerificarNeutralizacion();
      Print("Estado: ", (estadoNeutralizado ? "NEUTRALIZADO" : "NO neutralizado"));
      
      if(estadoNeutralizado)
      {
         Print("Acción: Esperando SEÑAL DE ESTRUCTURA M3+M1");
         Print("Precio referencia: ", DoubleToString(g_precio_activacion_roll_off, digits));
      }
      else
      {
         for(int i = 0; i < PositionsTotal(); i++)
         {
            if(posInfo.SelectByIndex(i))
            {
               if(posInfo.Magic() == g_numero_magico && posInfo.Symbol() == _Symbol)
               {
                  double tp = posInfo.TakeProfit();
                  if(tp != 0)
                  {
                     Print("TP fijo: ", DoubleToString(tp, digits));
                     break;
                  }
               }
            }
         }
         Print("Acción: Esperando TP o activación orden protección");
      }
      
      ultimoReporte = TimeCurrent();
   }
}

//+------------------------------------------------------------------+
//| Verificar si estamos en horario de PAUSA (1pm-8pm Nueva York)    |
//+------------------------------------------------------------------+
bool EsHorarioPausa()
{
   // Si el usuario desactivó la pausa desde el panel, nunca está en pausa
   if(!g_pausa_habilitada) return false;
   
   MqlDateTime tiempoServidor;
   TimeCurrent(tiempoServidor);
   int horaServidor = tiempoServidor.hour;
   
   int horaNY = horaServidor - 7;
   if(horaNY < 0) horaNY += 24;
   
   return (horaNY >= 13 && horaNY < 20);
}

//+------------------------------------------------------------------+
//| Trailing de la orden de protección pendiente                     |
//+------------------------------------------------------------------+
void GestionarTrailingOrdenProteccion()
{
   if(!g_roll_off_activo) return;
   if(g_estado_pausa) return;
   if(!g_trailing_activado) return;
   
   ulong ticketOrdenProteccion = 0;
   ENUM_ORDER_TYPE tipoOrden = ORDER_TYPE_BUY;
   double precioOrdenActual = 0;
   
   COrderInfo ordInfo;
   for(int i = 0; i < OrdersTotal(); i++)
   {
      if(ordInfo.SelectByIndex(i))
      {
         if(ordInfo.Magic() == g_numero_magico && ordInfo.Symbol() == _Symbol)
         {
            string com = ordInfo.Comment();
            if(StringFind(com, "RollOff_Proteccion") >= 0)
            {
               ticketOrdenProteccion = ordInfo.Ticket();
               tipoOrden = ordInfo.OrderType();
               precioOrdenActual = ordInfo.PriceOpen();
               break;
            }
         }
      }
   }
   
   if(ticketOrdenProteccion == 0) return;
   
   CPositionInfo posInfo;
   ENUM_POSITION_TYPE tipoGanadora = POSITION_TYPE_BUY;
   bool hayGanadora = false;
   
   for(int i = 0; i < PositionsTotal(); i++)
   {
      if(posInfo.SelectByIndex(i))
      {
         if(posInfo.Magic() == g_numero_magico && posInfo.Symbol() == _Symbol)
         {
            tipoGanadora = posInfo.PositionType();
            hayGanadora = true;
            break;
         }
      }
   }
   
   if(!hayGanadora) return;
   
   double punto = SymbolInfoDouble(_Symbol, SYMBOL_POINT);
   int digits = (int)SymbolInfoInteger(_Symbol, SYMBOL_DIGITS);
   
   double precioActual;
   if(tipoGanadora == POSITION_TYPE_BUY)
      precioActual = SymbolInfoDouble(_Symbol, SYMBOL_BID);
   else
      precioActual = SymbolInfoDouble(_Symbol, SYMBOL_ASK);
   
   double avanceTicks;
   if(tipoGanadora == POSITION_TYPE_BUY)
   {
      avanceTicks = (precioActual - g_trailing_precio_referencia) / punto;
   }
   else
   {
      avanceTicks = (g_trailing_precio_referencia - precioActual) / punto;
   }
   
   if(avanceTicks >= g_trailing_salto_ticks)
   {
      int saltos = (int)(avanceTicks / g_trailing_salto_ticks);
      int ticksAMover = saltos * g_trailing_salto_ticks;
      
      double nuevoPrecioOrden;
      if(tipoOrden == ORDER_TYPE_SELL_STOP)
      {
         nuevoPrecioOrden = precioOrdenActual + (ticksAMover * punto);
      }
      else if(tipoOrden == ORDER_TYPE_BUY_STOP)
      {
         nuevoPrecioOrden = precioOrdenActual - (ticksAMover * punto);
      }
      else
      {
         return;
      }
      
      nuevoPrecioOrden = NormalizeDouble(nuevoPrecioOrden, digits);
      
      int stopLevel = (int)SymbolInfoInteger(_Symbol, SYMBOL_TRADE_STOPS_LEVEL);
      double distanciaMinima = stopLevel * punto;
      double distanciaAlPrecio = MathAbs(nuevoPrecioOrden - precioActual);
      
      if(distanciaAlPrecio < distanciaMinima)
      {
         Print(">>> TRAILING: No se puede mover, violaría stop level del broker");
         return;
      }
      
      MqlTradeRequest request;
      MqlTradeResult result;
      ZeroMemory(request);
      ZeroMemory(result);
      
      request.action = TRADE_ACTION_MODIFY;
      request.order = ticketOrdenProteccion;
      request.price = nuevoPrecioOrden;
      request.type_time = ORDER_TIME_GTC;
      
      if(OrderSend(request, result))
      {
         Print(">>> TRAILING: Orden protección movida");
         Print("    De: ", DoubleToString(precioOrdenActual, digits));
         Print("    A:  ", DoubleToString(nuevoPrecioOrden, digits));
         Print("    Saltos aplicados: ", saltos, " × ", g_trailing_salto_ticks, " ticks = ", ticksAMover, " ticks");
         Print("    Precio actual: ", DoubleToString(precioActual, digits));
         Print("    Referencia anterior: ", DoubleToString(g_trailing_precio_referencia, digits));
         
         if(tipoGanadora == POSITION_TYPE_BUY)
            g_trailing_precio_referencia = g_trailing_precio_referencia + (ticksAMover * punto);
         else
            g_trailing_precio_referencia = g_trailing_precio_referencia - (ticksAMover * punto);
         
         g_trailing_precio_referencia = NormalizeDouble(g_trailing_precio_referencia, digits);
         
         Print("    Nueva referencia: ", DoubleToString(g_trailing_precio_referencia, digits));
      }
      else
      {
         Print(">>> TRAILING: Error al modificar orden - retcode: ", result.retcode);
      }
   }
}


// ================================================================
// GestionarSistemaRollOff
// El umbral de 77 ticks fue reemplazado por DetectarSenalEstructura()
// del módulo EstructuraM3M1.mqh
// ================================================================
void GestionarSistemaRollOff()
{
   if(!g_sistema_activo) return;
   
   if(g_nivel_actual < g_nivel_activacion_cierre)
      return;
   
   bool hayNeutralizacion = g_orden_neutralizadora_activada || VerificarNeutralizacion();
   
   // ========== PRIMERA ACTIVACIÓN ==========
   if(!g_roll_off_activo && hayNeutralizacion)
   {
      g_roll_off_activo = true;
      g_contador_rolloff = 0;
      
      double precioUltimaEntrada = 0;
      CPositionInfo posInfo;
      
      for(int i = 0; i < PositionsTotal(); i++)
      {
         if(posInfo.SelectByIndex(i))
         {
            if(posInfo.Magic() == g_numero_magico && posInfo.Symbol() == _Symbol)
            {
               string comentario = posInfo.Comment();
               int nivel = 0;
               
               if(StringFind(comentario, "Nivel_") >= 0)
               {
                  nivel = (int)StringToInteger(StringSubstr(comentario, 6));
               }
               
               if(nivel >= g_nivel_actual)
               {
                  precioUltimaEntrada = posInfo.PriceOpen();
               }
            }
         }
      }
      
      g_precio_activacion_roll_off = precioUltimaEntrada;
      
      Print("========================================");
      Print(">>> SISTEMA ROLL-OFF ACTIVADO <<<");
      Print(">>> CON DETECCIÓN ESTRUCTURA M3+M1");
      Print(">>> PRIMERA NEUTRALIZACIÓN DETECTADA");
      Print(">>> Nivel: ", g_nivel_actual);
      Print(">>> Precio referencia: ", DoubleToString(g_precio_activacion_roll_off, _Digits));
      Print("========================================");
      
      CTrade tradeGestion;
      tradeGestion.SetExpertMagicNumber(g_numero_magico);
      
      int tpSlQuitados = 0;
      for(int i = 0; i < PositionsTotal(); i++)
      {
         if(posInfo.SelectByIndex(i))
         {
            if(posInfo.Magic() == g_numero_magico && posInfo.Symbol() == _Symbol)
            {
               ulong ticket = posInfo.Ticket();
               double tp = posInfo.TakeProfit();
               double sl = posInfo.StopLoss();
               
               if(tp != 0 || sl != 0)
               {
                  if(tradeGestion.PositionModify(ticket, 0, 0))
                  {
                     tpSlQuitados++;
                  }
               }
            }
         }
      }
      
      Print(">>> TP/SL quitados: ", tpSlQuitados);
      Print(">>> Esperando SEÑAL DE ESTRUCTURA M3+M1 (al cierre de vela M1)");
      Print("========================================");
      
      return;
   }
   
   // ========== GESTIÓN ACTIVA ==========
   if(g_roll_off_activo)
   {
      MonitorearGanadorasRollOff();
      
      bool neutralizacionActiva = g_orden_neutralizadora_activada || VerificarNeutralizacion();
      
      if(neutralizacionActiva)
      {
         // ========== ESTADO PAUSA: Horario de spread alto ==========
         bool enPausa = EsHorarioPausa();
         
         if(enPausa && !g_estado_pausa)
         {
            g_estado_pausa = true;
            Print("========================================");
            Print(">>> ESTADO PAUSA ACTIVADO <<<");
            Print(">>> Horario de spread alto (1pm-8pm NY)");
            Print(">>> Bot neutralizado SIN evaluar estructura");
            Print("========================================");
         }
         else if(!enPausa && g_estado_pausa)
         {
            g_estado_pausa = false;
            g_precio_activacion_roll_off = (SymbolInfoDouble(_Symbol, SYMBOL_BID) +
                                           SymbolInfoDouble(_Symbol, SYMBOL_ASK)) / 2;
            Print("========================================");
            Print(">>> ESTADO PAUSA DESACTIVADO <<<");
            Print(">>> Son las 8pm NY - Mercado normal");
            Print(">>> Nueva referencia: ", DoubleToString(g_precio_activacion_roll_off, _Digits));
            Print(">>> Reanudando evaluación de estructura M3+M1");
            Print("========================================");
         }
         
         if(g_estado_pausa)
         {
            static datetime ultimoReportePausa = 0;
            if(TimeCurrent() - ultimoReportePausa > 60)
            {
               Print("--- PAUSA ACTIVA (spread alto) - Estructura no evaluada ---");
               ultimoReportePausa = TimeCurrent();
            }
            // No ejecutar Roll-Off durante pausa
         }
         else
         {
            // ============================================================
            // Análisis de estructura M3 + confirmación M1
            // ============================================================
            int senalEstructura = DetectarSenalEstructura();
            bool senalConfirmada = (senalEstructura != SENAL_SIN_SENAL);
            
            if(senalConfirmada && (TimeCurrent() - g_ultimo_roll_off) > 60)
            {
               g_ultima_senal_estructura = senalEstructura;
               
               Print("========================================");
               Print(">>> ROMPIMIENTO POR ESTRUCTURA M3+M1 <<<");
               Print(">>> Dirección señal: ",
                     (senalEstructura == SENAL_ALCISTA ? "ALCISTA" : "BAJISTA"));
               Print(">>> Roll-Off #", (g_contador_rolloff + 1));
               Print("========================================");
               
               bool exito = EjecutarRollOff();
               
               if(exito)
               {
                  Print(">>> Roll-Off completado");
                  g_orden_neutralizadora_activada = false;
               }
            }
         }
         
         static int contadorReporte = 0;
         contadorReporte++;
         if(contadorReporte >= 200)  // ~cada 200 ticks
         {
            Print("--- Roll-Off activo (Estructura M3+M1) ---");
            Print("Estado: NEUTRALIZADO");
            Print("Ciclos Roll-Off ejecutados: ", g_contador_rolloff);
            Print("Esperando: Tendencia M3 + retroceso M1 + rompimiento con cuerpo");
            if(g_estado_pausa)
               Print(">>> PAUSA ACTIVA - Estructura no evaluada");
            contadorReporte = 0;
         }
      }
      else
      {
         // ========== PASO 7: RECALCULAR TP SI ESTÁ CERCA ==========
         double tpActual = 0;
         ENUM_POSITION_TYPE tipoGanadoras = POSITION_TYPE_BUY;
         
         CPositionInfo posInfoPaso7;
         for(int i = 0; i < PositionsTotal(); i++)
         {
            if(posInfoPaso7.SelectByIndex(i))
            {
               if(posInfoPaso7.Magic() == g_numero_magico && posInfoPaso7.Symbol() == _Symbol)
               {
                  tpActual = posInfoPaso7.TakeProfit();
                  tipoGanadoras = posInfoPaso7.PositionType();
                  
                  if(tpActual != 0)
                     break;
               }
            }
         }
         
         if(tpActual != 0)
         {
            double precioActual;
            if(tipoGanadoras == POSITION_TYPE_BUY)
               precioActual = SymbolInfoDouble(_Symbol, SYMBOL_BID);
            else
               precioActual = SymbolInfoDouble(_Symbol, SYMBOL_ASK);
            
            double punto = SymbolInfoDouble(_Symbol, SYMBOL_POINT);
            double distancia = MathAbs(tpActual - precioActual);
            int ticksHastaTP = (int)MathRound(distancia / punto);
            
            static datetime ultimoRecalculo = 0;
            
            int posicionesParaPaso7 = 0;
            for(int p = 0; p < PositionsTotal(); p++)
            {
               CPositionInfo posCheck;
               if(posCheck.SelectByIndex(p))
               {
                  if(posCheck.Magic() == g_numero_magico && posCheck.Symbol() == _Symbol)
                     posicionesParaPaso7++;
               }
            }
            
            if(ticksHastaTP <= 10 && ticksHastaTP > 0 &&
               (TimeCurrent() - ultimoRecalculo) > 60 && posicionesParaPaso7 >= 2)
            {
               Print(">>> PASO 7: RECALCULAR TP (", ticksHastaTP, " ticks) <<<");
               
               bool exito = EjecutarRollOff();
               
               if(exito)
               {
                  Print(">>> TP recalculado");
                  ultimoRecalculo = TimeCurrent();
               }
            }
            
            static int contadorPaso7 = 0;
            contadorPaso7++;
            if(contadorPaso7 >= 100 && ticksHastaTP > 21)
            {
               Print("--- Paso 7: ", ticksHastaTP, " ticks al TP ---");
               contadorPaso7 = 0;
            }
         }
         
         static datetime ultimoReporteNoNeutralizado = 0;
         if(TimeCurrent() - ultimoReporteNoNeutralizado > 30)
         {
            Print("--- Roll-Off activo ---");
            Print("Estado: NO neutralizado");
            Print("Última señal: ", (g_ultima_senal_estructura == SENAL_ALCISTA ? "ALCISTA" :
                                     (g_ultima_senal_estructura == SENAL_BAJISTA ? "BAJISTA" : "N/A")));
            Print("Ciclos ejecutados: ", g_contador_rolloff);
            ultimoReporteNoNeutralizado = TimeCurrent();
         }
      }
   }
}

