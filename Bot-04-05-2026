//+------------------------------------------------------------------+
//| Toggle del Modo Pausa (botón en el panel)                        |
//| Activa/desactiva la pausa horaria de 1pm-8pm NY en cualquier     |
//| momento. Si se desactiva mientras el bot está actualmente en     |
//| pausa, sale de pausa y restablece el precio de referencia.       |
//+------------------------------------------------------------------+
void CPanelTrading::AlHacerClickPausa(void)
{
   g_pausa_habilitada = !g_pausa_habilitada;
   
   Print("========================================");
   Print(">>> MODO PAUSA ", (g_pausa_habilitada ? "HABILITADO" : "DESHABILITADO"), " <<<");
   Print(">>> Pausa horaria 1pm-8pm NY: ",
         (g_pausa_habilitada ? "ACTIVA cuando llegue el horario"
                             : "IGNORADA - bot evalúa estructura siempre"));
   Print("========================================");
   
   // Si el usuario desactiva la pausa MIENTRAS el bot está en pausa,
   // forzamos la salida del estado pausa para reanudar evaluación inmediata
   if(!g_pausa_habilitada && g_estado_pausa)
   {
      g_estado_pausa = false;
      g_precio_activacion_roll_off = (SymbolInfoDouble(_Symbol, SYMBOL_BID) +
                                      SymbolInfoDouble(_Symbol, SYMBOL_ASK)) / 2;
      Print(">>> El bot estaba en pausa, se sale de pausa AHORA");
      Print(">>> Nueva referencia: ", DoubleToString(g_precio_activacion_roll_off, _Digits));
   }
   
   ActualizarAparienciaBotonPausa();
   ChartRedraw();
}

//+------------------------------------------------------------------+
//| Refresca el texto y color del botón Modo Pausa                   |
//| Verde "ON" cuando la pausa está habilitada                       |
//| Gris "OFF" cuando está deshabilitada                             |
//+------------------------------------------------------------------+
void CPanelTrading::ActualizarAparienciaBotonPausa(void)
{
   if(g_pausa_habilitada)
   {
      m_boton_pausa.Text("ON");
      m_boton_pausa.ColorBackground(clrGreen);
      m_boton_pausa.ColorBorder(clrGreen);
   }
   else
   {
      m_boton_pausa.Text("OFF");
      m_boton_pausa.ColorBackground(clrDimGray);
      m_boton_pausa.ColorBorder(clrDimGray);
   }
}


