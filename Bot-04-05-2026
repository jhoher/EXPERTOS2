//+------------------------------------------------------------------+
//| Función de inicialización del Expert Advisor                     |
//+------------------------------------------------------------------+
int OnInit()
{
   trade.SetExpertMagicNumber(g_numero_magico);
   
   // ========== INICIALIZAR MÓDULO DE ESTRUCTURA M3+M1 ==========
   if(!InicializarEstructura())
   {
      Print("========================================");
      Print(">>> ADVERTENCIA: Módulo Estructura M3+M1 NO inicializado");
      Print(">>> El bot arrancará pero el Roll-Off NO se disparará");
      Print("========================================");
   }
   // =====================================================================
   
   g_estado_restaurado = RestaurarEstadoCompleto();
   
   if(!g_estado_restaurado)
   {
      g_roll_off_activo = false;
      g_precio_activacion_roll_off = 0;
      g_ticks_umbral_roll_off = 77;
      g_ultimo_roll_off = 0;
      
      Print("========================================");
      Print("Sistema Roll-Off inicializado (v4.3)");
      Print("DISPARO: Estructura M3+M1 (reemplaza 77 ticks)");
      Print("DIRECCIÓN: Señal M3 decide qué lado cerrar");
      Print("========================================");
   }
   
   if(!DialogoExterno.Create(0, "CoberturaEspecial", 0, 50, 50, 300, 410))
      return(INIT_FAILED);
   
   if(!DialogoExterno.Run())
      return(INIT_FAILED);
   
   if(g_estado_restaurado)
   {
      DialogoExterno.RestaurarValoresPanel();
      // Refrescar el botón Modo Pausa con el valor restaurado
      DialogoExterno.ActualizarAparienciaBotonPausa();
      Print(">>> Estado restaurado exitosamente tras cambio de temporalidad");
      Print(">>> Modo Pausa: ", (g_pausa_habilitada ? "HABILITADO" : "DESHABILITADO"));
   }
   
   ChartRedraw();
   return(INIT_SUCCEEDED);
}

//+------------------------------------------------------------------+
//| Función de desinicialización del Expert Advisor                  |
//+------------------------------------------------------------------+
void OnDeinit(const int reason)
{
   Print(">>> OnDeinit - Razón: ", reason);
   
   // ========== LIBERAR MÓDULO DE ESTRUCTURA ==========
   // Borra TODAS las marcas de estructura M3 y M1 del gráfico
   // (puntos AA/BB/AB/BA y etiquetas, prefijo "EST_").
   // Se ejecuta SIEMPRE, sin importar la razón del deinit, para
   // garantizar que el chart quede limpio al cerrar/quitar el bot.
   LiberarEstructura();
   ChartRedraw();
   Print(">>> Marcas de estructura M3 y M1 borradas del gráfico");
   // ===================================================
   
   if(reason == REASON_CHARTCHANGE)
   {
      GuardarEstadoCompleto();
      DialogoExterno.GuardarValoresPanel();
      Print(">>> Todo guardado - Listo para restaurar en nueva temporalidad");
   }
   else
   {
      LimpiarGlobalVariables();
      Print(">>> GlobalVariables limpiadas (no fue cambio de temporalidad)");
   }
   
   DialogoExterno.Destroy(reason);
}

