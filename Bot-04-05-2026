void CPanelTrading::GuardarValoresPanel()
{
   string prefijo = "EA_PANEL_" + _Symbol + "_";
   
   double lote = StringToDouble(m_entrada_lote.Text());
   double tp1 = StringToDouble(m_entrada_tp1.Text());
   double tp2 = StringToDouble(m_entrada_tp2.Text());
   double dist = StringToDouble(m_entrada_dist.Text());
   double cierre = StringToDouble(m_entrada_cierre.Text());
   double ganancia = StringToDouble(m_entrada_ganancia.Text());
   
   GlobalVariableSet(prefijo + "LOTE", lote);
   GlobalVariableSet(prefijo + "TP1", tp1);
   GlobalVariableSet(prefijo + "TP2", tp2);
   GlobalVariableSet(prefijo + "DIST", dist);
   GlobalVariableSet(prefijo + "CIERRE", cierre);
   GlobalVariableSet(prefijo + "GANANCIA", ganancia);
   
   Print(">>> Panel guardado - Lote:", DoubleToString(lote, 2),
         " TP1:", DoubleToString(tp1, 0),
         " TP2:", DoubleToString(tp2, 0),
         " Dist:", DoubleToString(dist, 0),
         " Cierre:", DoubleToString(cierre, 0),
         " GananciaM:", DoubleToString(ganancia, 2));
}

void CPanelTrading::RestaurarValoresPanel()
{
   string prefijo = "EA_PANEL_" + _Symbol + "_";
   
   if(!GlobalVariableCheck(prefijo + "LOTE"))
   {
      Print(">>> No hay valores de panel guardados");
      return;
   }
   
   double lote = GlobalVariableGet(prefijo + "LOTE");
   double tp1 = GlobalVariableGet(prefijo + "TP1");
   double tp2 = GlobalVariableGet(prefijo + "TP2");
   double dist = GlobalVariableGet(prefijo + "DIST");
   double cierre = GlobalVariableGet(prefijo + "CIERRE");
   double ganancia = GlobalVariableGet(prefijo + "GANANCIA");
   
   m_entrada_lote.Text(DoubleToString(lote, 2));
   m_entrada_tp1.Text(IntegerToString((int)tp1));
   m_entrada_tp2.Text(IntegerToString((int)tp2));
   m_entrada_dist.Text(IntegerToString((int)dist));
   m_entrada_cierre.Text(IntegerToString((int)cierre));
   m_entrada_ganancia.Text(DoubleToString(ganancia, 2));
   
   GlobalVariableDel(prefijo + "LOTE");
   GlobalVariableDel(prefijo + "TP1");
   GlobalVariableDel(prefijo + "TP2");
   GlobalVariableDel(prefijo + "DIST");
   GlobalVariableDel(prefijo + "CIERRE");
   GlobalVariableDel(prefijo + "GANANCIA");
   
   Print(">>> Panel restaurado - Lote:", DoubleToString(lote, 2),
         " TP1:", DoubleToString(tp1, 0),
         " TP2:", DoubleToString(tp2, 0),
         " Dist:", DoubleToString(dist, 0),
         " Cierre:", DoubleToString(cierre, 0),
         " GananciaM:", DoubleToString(ganancia, 2));
}

bool CPanelTrading::Create(const long chart, const string name, const int subwin, const int x1, const int y1, const int x2, const int y2)
{
   if(!CAppDialog::Create(chart, "Cobertura->FIN DEL STOP LOSS", subwin, x1, y1, x2, y2))
      return(false);
   
   if(!m_panel_principal.Create(m_chart_id, m_name+"PanelPrincipal", m_subwin, 0, 0, ClientAreaWidth(), ClientAreaHeight()))
      return(false);
   m_panel_principal.ColorBackground(clrBlack);
   m_panel_principal.ColorBorder(clrDarkGray);
   if(!Add(m_panel_principal))
      return(false);
   
   int desplazamiento_y = 10;
   int etiqueta_x = 10;
   int entrada_x = 120;
   int altura_fila = 30;
   
   CrearEtiqueta(m_etiqueta_lote, etiqueta_x, desplazamiento_y, "Lote Inicial:");
   CrearCampoEntrada(m_entrada_lote, entrada_x, desplazamiento_y);
   m_entrada_lote.Text("0.01");
   
   desplazamiento_y += altura_fila;
   CrearEtiqueta(m_etiqueta_tp1, etiqueta_x, desplazamiento_y, "TP E1:");
   CrearCampoEntrada(m_entrada_tp1, entrada_x, desplazamiento_y);
   m_entrada_tp1.Text("333");
   
   desplazamiento_y += altura_fila;
   CrearEtiqueta(m_etiqueta_tp2, etiqueta_x, desplazamiento_y, "TP E2:");
   CrearCampoEntrada(m_entrada_tp2, entrada_x, desplazamiento_y);
   m_entrada_tp2.Text("333");
   
   desplazamiento_y += altura_fila;
   CrearEtiqueta(m_etiqueta_dist, etiqueta_x, desplazamiento_y, "Dist. E1/E2:");
   CrearCampoEntrada(m_entrada_dist, entrada_x, desplazamiento_y);
   m_entrada_dist.Text("55");
   
   desplazamiento_y += altura_fila;
   CrearEtiqueta(m_etiqueta_cierre, etiqueta_x, desplazamiento_y, "Cierre virtual:");
   CrearCampoEntrada(m_entrada_cierre, entrada_x, desplazamiento_y);
   m_entrada_cierre.Text("4");
   
   desplazamiento_y += altura_fila;
   CrearEtiqueta(m_etiqueta_ganancia, etiqueta_x, desplazamiento_y, "GananciaM:");
   CrearCampoEntrada(m_entrada_ganancia, entrada_x, desplazamiento_y);
   m_entrada_ganancia.Text("0.01");
   
   desplazamiento_y += altura_fila + 20;
   int altura_boton = 35;
   int espacio_botones = 10;
   int ancho_total = (entrada_x + 100) - etiqueta_x;
   int ancho_boton = (ancho_total - espacio_botones) / 2;
   
   CrearBoton(m_boton_venta, etiqueta_x, desplazamiento_y, ancho_boton, altura_boton, "VENTA", clrRed);
   int compra_boton_x = etiqueta_x + ancho_boton + espacio_botones;
   CrearBoton(m_boton_compra, compra_boton_x, desplazamiento_y, ancho_boton, altura_boton, "COMPRA", clrBlue);
   
   // ========== Fila MODO PAUSA (etiqueta + botón ON/OFF) ==========
   desplazamiento_y += altura_boton + 15;
   CrearEtiqueta(m_etiqueta_pausa, etiqueta_x, desplazamiento_y + 5, "Modo Pausa:");
   // Botón ON/OFF a la derecha. Apariencia inicial se aplica con
   // ActualizarAparienciaBotonPausa() según el valor de g_pausa_habilitada.
   if(!m_boton_pausa.Create(m_chart_id, m_name + "BotonPausa", m_subwin,
                            entrada_x, desplazamiento_y,
                            entrada_x + 100, desplazamiento_y + 25))
      return(false);
   m_boton_pausa.FontSize(9);
   m_boton_pausa.Color(clrWhite);
   if(!Add(m_boton_pausa))
      return(false);
   ActualizarAparienciaBotonPausa();
   
   return(true);
}

